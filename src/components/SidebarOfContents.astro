---
const dfAbout = '/img/df-about.webp';
import Icon from './Icon.astro';
---

<!-- 隐藏的数据存储：传递 dfCover 给客户端脚本 -->
<div id="sidebar-data" data-df-about={dfAbout} class="hidden"></div>

<!-- 侧边功能图标组 - 与目录水平对称 -->
<div
  id="sidebar-of-contents"
  class="hidden xl:flex fixed top-1/2 -translate-y-1/2 left-[max(4rem,calc((100vw-1340px)/2-6rem))] z-40 flex-col gap-4 sidebar-icon-group"
>
  <!-- 返回上一页按钮 -->
  <div
    id="back-to-top"
    class="flex items-center justify-end w-[180px] group/bar cursor-pointer opacity-100 transition-opacity duration-500 relative"
    aria-label="返回上一页"
  >
    <!-- 左侧提示信息框（在按钮左边） -->
    <div class="absolute right-12 px-3 py-1.5 rounded-lg bg-card-light dark:bg-card-dark border border-border-light dark:border-border-dark shadow-lg opacity-0 group-hover/bar:opacity-100 transition-all duration-300 pointer-events-none whitespace-nowrap translate-x-2 group-hover/bar:translate-x-0">
      <span class="text-sm font-medium text-text-light dark:text-text-dark">返回上一页</span>
      <!-- 小三角形指示器 - 指向右侧 -->
      <div class="absolute right-[-6px] top-1/2 -translate-y-1/2 w-0 h-0 border-t-[6px] border-t-transparent border-b-[6px] border-b-transparent border-l-[6px] border-l-border-light dark:border-l-border-dark"></div>
      <div class="absolute right-[-5px] top-1/2 -translate-y-1/2 w-0 h-0 border-t-[5px] border-t-transparent border-b-[5px] border-b-transparent border-l-[5px] border-l-card-light dark:border-l-card-dark"></div>
    </div>
    <!-- 圆形背景 + 向左箭头图标 -->
    <div class="w-10 h-10 rounded-full bg-card-light dark:bg-card-dark border border-border-light dark:border-border-dark flex items-center justify-center group-hover/bar:bg-primary-light/10 dark:group-hover/bar:bg-primary-dark/10 group-hover/bar:border-primary-light/40 dark:group-hover/bar:border-primary-dark/40 fluid-icon shadow-md hover:shadow-lg">
      <Icon name="chevron-left" class="w-5 h-5 text-text-light/70 dark:text-text-dark/70 group-hover/bar:text-primary-light dark:group-hover/bar:text-primary-dark transition-all duration-300" />
    </div>
  </div>

  <!-- 分享按钮（占位，始终显示） -->
  <div
    id="share-button"
    class="flex items-center justify-end w-[180px] group/bar cursor-pointer opacity-100 transition-opacity duration-500 relative"
    aria-label="分享"
  >
    <!-- 分享面板 - hover时直接显示 -->
    <div id="share-panel" class="absolute right-12 w-[300px] p-4 rounded-xl bg-card-light dark:bg-card-dark border border-border-light dark:border-border-dark tooltip group-hover/bar:opacity-100 group-hover/bar:visible group-hover/bar:scale-100 group-hover/bar:pointer-events-auto origin-right transform-gpu will-change-transform">
      <div class="flex flex-col gap-3">
        <!-- 海报预览区域 -->
        <div id="poster-preview" class="w-full rounded-lg overflow-hidden border border-border-light dark:border-border-dark bg-bg-light dark:bg-bg-dark relative" style="aspect-ratio: 3/4;">
          <img id="poster-image" src="" alt="海报预览" class="absolute inset-0 w-full h-full object-contain" />
        </div>

        <!-- 操作按钮 -->
        <div class="relative w-full h-11 p-1 flex items-center bg-neutral-100/60 dark:bg-neutral-900/40 backdrop-blur-md rounded-xl border border-border-light dark:border-border-dark select-none overflow-hidden">
          
          <button id="copy-link-btn" class="group/btn relative z-10 flex-[1.25] hover:flex-[1.8] h-full flex items-center justify-center gap-2 px-3 text-text-light/60 dark:text-text-dark/50 hover:text-text-light dark:hover:text-text-dark text-xs font-medium bg-white/50 dark:bg-white/2 hover:bg-white dark:hover:bg-neutral-800 rounded-lg shadow-sm hover:shadow-md active:scale-[0.97] fluid-btn" style="transition-timing-function: cubic-bezier(0.25,1,0.5,1); transition-duration: 500ms;">
            <Icon name="copy" class="w-3.5 h-3.5 opacity-40 group-hover/btn:opacity-90 group-hover/btn:translate-x-px group-hover/btn:translate-y-px transition-all duration-300" />
            <span class="tracking-wide">复制链接</span>
          </button>

          <div class="w-1 h-full pointer-events-none"></div>

          <button id="download-poster-btn" class="group/btn relative z-10 flex-1 hover:flex-[1.8] h-full flex items-center justify-center gap-2 px-3 text-text-light/70 dark:text-text-dark/60 hover:text-white dark:hover:text-neutral-900 text-xs font-semibold bg-transparent hover:bg-neutral-900 dark:hover:bg-neutral-100 rounded-lg active:scale-[0.97] fluid-btn" style="transition-timing-function: cubic-bezier(0.25,1,0.5,1); transition-duration: 500ms;">
            <span class="tracking-wide">下载海报</span>
            <Icon name="download" class="w-3.5 h-3.5 opacity-40 group-hover/btn:opacity-90 group-hover/btn:translate-y-px transition-all duration-300" />
          </button>

        </div>
      </div>
      <!-- 小三角形指示器 - 指向右侧按钮 -->
      <div class="absolute right-[-6px] top-1/2 -translate-y-1/2 w-0 h-0 border-t-[6px] border-t-transparent border-b-[6px] border-b-transparent border-l-[6px] border-l-border-light dark:border-l-border-dark"></div>
      <div class="absolute right-[-5px] top-1/2 -translate-y-1/2 w-0 h-0 border-t-[5px] border-t-transparent border-b-[5px] border-b-transparent border-l-[5px] border-l-card-light dark:border-l-card-dark"></div>
    </div>

    <!-- 圆形背景 + 分享图标 -->
    <div class="w-10 h-10 rounded-full bg-card-light dark:bg-card-dark border border-border-light dark:border-border-dark flex items-center justify-center group-hover/bar:bg-primary-light/10 dark:group-hover/bar:bg-primary-dark/10 group-hover/bar:border-primary-light/30 dark:group-hover/bar:border-primary-dark/30 fluid-icon shadow-md hover:shadow-lg">
      <Icon name="share" class="w-5 h-5 text-text-light/70 dark:text-text-dark/70 group-hover/bar:text-primary-light dark:group-hover/bar:text-primary-dark transition-all duration-300" />
    </div>
  </div>

  <!-- 打赏按钮（占位，始终显示） -->
  <div
    id="reward-button"
    class="flex items-center justify-end w-[180px] group/bar cursor-pointer opacity-100 transition-opacity duration-500 relative"
    aria-label="打赏"
  >
    <!-- 打赏面板 - hover时直接显示 -->
    <div id="reward-large-panel" class="absolute right-12 w-[300px] p-4 rounded-xl bg-card-light dark:bg-card-dark border border-border-light dark:border-border-dark tooltip group-hover/bar:opacity-100 group-hover/bar:visible group-hover/bar:scale-100 group-hover/bar:pointer-events-auto origin-right transform-gpu will-change-transform">
      <div class="flex flex-col items-center gap-4">
        
        <div class="w-full flex items-center justify-between px-1">
          <h3 class=" text-text-light/70 dark:text-text-dark/70 text-base font-semibold">随缘投喂</h3>
          <div class="flex items-center justify-center">
            <Icon name="coffee" class="w-4 h-4 text-neutral-400 dark:text-neutral-500" />
          </div>
        </div>

        <div class="relative w-full h-9 p-0.5 flex items-center bg-neutral-100/80 dark:bg-neutral-900/60 backdrop-blur-md rounded-lg border border-neutral-200/40 dark:border-neutral-800/40 select-none overflow-hidden">
          <button id="tab-wechat" class="reward-tab flex-1 h-full flex items-center justify-center gap-1.5 text-xs font-medium rounded-md transition-all duration-300 z-10 text-text-light dark:text-text-dark bg-white dark:bg-neutral-800 shadow-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
            <span>微信</span>
          </button>
          <button id="tab-alipay" class="reward-tab flex-1 h-full flex items-center justify-center gap-1.5 text-xs font-medium rounded-md transition-all duration-300 z-10 text-text-light/50 dark:text-text-dark/40 hover:text-text-light dark:hover:text-text-dark">
            <span class="w-1.5 h-1.5 rounded-full bg-blue-500/40"></span>
            <span>支付宝</span>
          </button>
        </div>

        <div class="group/qr relative w-36 h-36 p-2 rounded-xl bg-neutral-50 dark:bg-neutral-950 border border-neutral-200/40 dark:border-neutral-800/40 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg dark:hover:shadow-neutral-950/50">
          
          <div id="qr-wechat" class="reward-qr absolute inset-2 transition-all duration-500 opacity-100 scale-100 transform-gpu">
            <img src="/img/wechatGood.webp" alt="微信赞赏码" class="w-full h-full object-cover rounded-lg filter contrast-[1.02] dark:opacity-90" />
          </div>
          
          <div id="qr-alipay" class="reward-qr absolute inset-2 transition-all duration-500 opacity-0 scale-95 pointer-events-none transform-gpu">
            <img src="/img/alipayGood.webp" alt="支付宝赞赏码" class="w-full h-full object-cover rounded-lg filter contrast-[1.02] dark:opacity-90" />
          </div>
          
        </div>

        <p class="text-sm dark:text-text-dark/70 text-text-light/70 text-center">
          喜欢的话，扫码支持一下作者吧 (•̀ᴗ•́)و 
        </p>
        
      </div>

      <div class="absolute right-[-6px] top-1/2 -translate-y-1/2 w-0 h-0 border-t-[6px] border-t-transparent border-b-[6px] border-b-transparent border-l-[6px] border-l-border-light dark:border-l-border-dark"></div>
      <div class="absolute right-[-5px] top-1/2 -translate-y-1/2 w-0 h-0 border-t-[5px] border-t-transparent border-b-[5px] border-b-transparent border-l-[5px] border-l-card-light dark:border-l-card-dark"></div>
    </div>

    <!-- 圆形背景 + 打赏图标 -->
    <div class="w-10 h-10 rounded-full bg-card-light dark:bg-card-dark border border-border-light dark:border-border-dark flex items-center justify-center group-hover/bar:bg-primary-light/10 dark:group-hover/bar:bg-primary-dark/10 group-hover/bar:border-primary-light/30 dark:group-hover/bar:border-primary-dark/30 fluid-icon shadow-md hover:shadow-lg">
      <Icon name="heart" class="w-5 h-5 text-text-light/70 dark:text-text-dark/70 group-hover/bar:text-primary-light dark:group-hover/bar:text-primary-dark transition-all duration-300" />
    </div>
  </div>

  <!-- 订阅按钮（占位，始终显示） -->
  <div
    id="subscribe-button"
    class="flex items-center justify-end w-[180px] group/bar cursor-pointer opacity-100 transition-opacity duration-500 relative"
    aria-label="订阅"
  >
    <!-- 订阅面板 - hover时直接显示 -->
    <div id="subscribe-panel" class="absolute right-12 w-[300px] p-5 rounded-xl bg-card-light dark:bg-card-dark border border-border-light dark:border-border-dark tooltip group-hover/bar:opacity-100 group-hover/bar:visible group-hover/bar:scale-100 group-hover/bar:pointer-events-auto origin-right transform-gpu will-change-transform">
      <div class="flex flex-col gap-5">
        <div class="flex items-center gap-2.5">
          <div class="w-9 h-9 rounded-lg bg-linear-to-br from-[#f26522]/20 to-[#f26522]/5 flex items-center justify-center shrink-0">
            <Icon name="rss" class="w-5 h-5 text-[#f26522]" />
          </div>
          <div class="flex flex-col">
            <h3 class="text-sm font-semibold text-text-light/90 dark:text-text-dark/90 leading-tight">RSS 订阅</h3>
            <p class="text-[11px] text-text-light/50 dark:text-text-dark/40 mt-0.5">获取最新文章推送</p>
          </div>
        </div>

        <button
          id="rss-copy-btn"
          data-rss-url="https://log.1k.ink/rss.xml"
          class="w-full relative group/btn flex flex-col gap-2 p-3.5 bg-background-light/20 dark:bg-background-dark/10 hover:bg-background-light/60 dark:hover:bg-background-dark/30 border border-dashed border-border-light dark:border-border-dark/10 hover:border-[#f26522]/50 dark:hover:border-[#f26522]/50 rounded-xl fluid-btn text-left active:scale-[0.98]"
        >
          <div class="flex items-center justify-between w-full">
            <span class="text-[10px] px-1.5 py-0.5 -ml-1.5 rounded-md font-medium text-dim group-hover/btn:text-[#f26522]/80 group-hover/btn:bg-[#f26522]/5 transition-all duration-300">
              订阅地址
            </span>
            
            <div class="flex items-center gap-1 text-[11px] font-medium text-[#f26522] opacity-0 group-hover/btn:opacity-100 translate-x-1 group-hover/btn:translate-x-0 transition-all duration-300">
              <span id="rss-copy-text" class="text-[10px]">点击复制</span>
              <Icon name="copy-sm" class="w-3 h-3" />
            </div>
          </div>
          
          <code class="text-[11px] text-text-light/70 dark:text-text-dark/70 group-hover/btn:text-text-light dark:group-hover/btn:text-text-dark break-all leading-normal selection:bg-transparent transition-colors duration-200">
            https://log.1k.ink/rss.xml
          </code>
        </button>

        <div class="flex items-center justify-center gap-2 px-1">
          <div class="flex -space-x-1 opacity-40 group-hover/bar:opacity-60 transition-opacity duration-300">
            <div class="w-3.5 h-3.5 rounded-full bg-text-light/10 dark:bg-text-dark/10 border border-card-light dark:border-card-dark flex items-center justify-center text-[7px] font-bold text-text-light dark:text-text-dark">F</div>
            <div class="w-3.5 h-3.5 rounded-full bg-text-light/10 dark:bg-text-dark/10 border border-card-light dark:border-card-dark flex items-center justify-center text-[7px] font-bold text-text-light dark:text-text-dark">I</div>
            <div class="w-3.5 h-3.5 rounded-full bg-text-light/10 dark:bg-text-dark/10 border border-card-light dark:border-card-dark flex items-center justify-center text-[7px] font-bold text-text-light dark:text-text-dark">R</div>
          </div>
          <p class="text-[10px] text-dim tracking-wide">
            支持 Feedly、Inoreader、Reeder 等
          </p>
        </div>
      </div>

      <div class="absolute right-[-6px] top-1/2 -translate-y-1/2 w-0 h-0 border-t-[6px] border-t-transparent border-b-[6px] border-b-transparent border-l-[6px] border-l-border-light dark:border-l-border-dark"></div>
      <div class="absolute right-[-5px] top-1/2 -translate-y-1/2 w-0 h-0 border-t-[5px] border-t-transparent border-b-[5px] border-b-transparent border-l-[5px] border-l-card-light dark:border-l-card-dark"></div>
    </div>

    <!-- 圆形背景 + 订阅图标 -->
    <div class="w-10 h-10 rounded-full bg-card-light dark:bg-card-dark border border-border-light dark:border-border-dark flex items-center justify-center group-hover/bar:bg-primary-light/10 dark:group-hover/bar:bg-primary-dark/10 group-hover/bar:border-primary-light/30 dark:group-hover/bar:border-primary-dark/30 fluid-icon shadow-md hover:shadow-lg">
      <Icon name="bell" class="w-5 h-5 text-text-light/70 dark:text-text-dark/70 group-hover/bar:text-primary-light dark:group-hover/bar:text-primary-dark transition-all duration-300" />
    </div>
  </div>

  <!-- 直达评论区按钮（占位，始终显示） -->
  <div
    id="jump-to-comments"
    class="flex items-center justify-end w-[180px] group/bar cursor-pointer opacity-100 transition-opacity duration-500 relative"
    aria-label="直达评论区"
  >
    <!-- 左侧提示信息框（在按钮左边） -->
    <div class="absolute right-12 px-3 py-1.5 rounded-lg bg-card-light dark:bg-card-dark border border-border-light dark:border-border-dark shadow-lg opacity-0 group-hover/bar:opacity-100 transition-all duration-300 pointer-events-none whitespace-nowrap translate-x-2 group-hover/bar:translate-x-0">
      <span class="text-sm font-medium text-text-light dark:text-text-dark">直达评论区</span>
      <!-- 小三角形指示器 - 指向右侧 -->
      <div class="absolute right-[-6px] top-1/2 -translate-y-1/2 w-0 h-0 border-t-[6px] border-t-transparent border-b-[6px] border-b-transparent border-l-[6px] border-l-border-light dark:border-l-border-dark"></div>
      <div class="absolute right-[-5px] top-1/2 -translate-y-1/2 w-0 h-0 border-t-[5px] border-t-transparent border-b-[5px] border-b-transparent border-l-[5px] border-l-card-light dark:border-l-card-dark"></div>
    </div>
    <!-- 圆形背景 + 评论图标 -->
    <div class="w-10 h-10 rounded-full bg-card-light dark:bg-card-dark border border-border-light dark:border-border-dark flex items-center justify-center group-hover/bar:bg-primary-light/10 dark:group-hover/bar:bg-primary-dark/10 group-hover/bar:border-primary-light/30 dark:group-hover/bar:border-primary-dark/30 fluid-icon shadow-md hover:shadow-lg">
      <Icon name="comment" class="w-5 h-5 text-text-light/70 dark:text-text-dark/70 group-hover/bar:text-primary-light dark:group-hover/bar:text-primary-dark transition-all duration-300" />
    </div>
  </div>

  <!-- 音乐按钮 -->
  <div
    id="music-button"
    class="flex items-center justify-end w-[180px] group/bar cursor-pointer opacity-100 transition-opacity duration-500 relative"
    aria-label="音乐"
  >
    <!-- 音乐面板 -->
    <div id="music-panel" 
        class="absolute right-12 w-[300px] p-5 rounded-xl select-none
                bg-card-light dark:bg-card-dark border border-border-light dark:border-border-dark
                tooltip group-hover/bar:opacity-100 group-hover/bar:visible group-hover/bar:scale-100 group-hover/bar:pointer-events-auto 
                origin-right transform-gpu will-change-transform">
      
      <div class="relative flex flex-col gap-5 z-10">
        
        <div class="flex justify-between items-start gap-4">
          <div class="flex flex-col min-w-0 flex-1">
            <span class="text-[10px] font-mono tracking-widest text-text-light/40 dark:text-text-dark/30 uppercase leading-none mb-1.5">
              网易云歌单
            </span>
            <span id="sidebar-song" class="text-base font-bold text-text-light/90 dark:text-text-dark/90 truncate tracking-tight leading-tight">
              未播放
            </span>
            <span id="sidebar-artist" class="text-xs font-mono text-text-light/40 dark:text-text-dark/30 truncate mt-1">
              --
            </span>
          </div>

          <div class="relative w-16 h-16 rounded-xl overflow-hidden shrink-0 
                      shadow-[0_8px_20px_rgba(0,0,0,0.08)] dark:shadow-[0_8px_24px_rgba(0,0,0,0.4)]
                      border border-border-light dark:border-border-dark">
            <img id="sidebar-cover" src="/img/df-cover.webp" alt="封面" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-linear-to-b from-transparent via-transparent to-black/5 pointer-events-none"></div>
          </div>
        </div>

        <div class="space-y-1 group/progress cursor-pointer">
          <div class="h-1 w-full bg-zinc-200/60 dark:bg-zinc-800/80 rounded-full transition-all duration-300 relative">
            <div 
              id="sidebar-progress-bar" 
              class="h-full bg-primary-light dark:bg-primary-dark rounded-full transition-all duration-100 relative" 
              style="width: 0%"
            >
              <div class="absolute inset-0 bg-linear-to-r from-black/10 via-transparent to-white/40 dark:from-black/20 dark:to-white/20 rounded-full"></div>
              <div class="absolute -right-1 top-1/2 -translate-y-1/2 w-2 h-2 bg-white dark:bg-zinc-100 rounded-full shadow-[0_1px_3px_rgba(0,0,0,0.3)] scale-0 group-hover/progress:scale-100 transition-transform duration-200 ease-out z-10"></div>
            </div>
          </div>
          <div class="flex justify-between text-[10px] font-bold tracking-wider text-text-light/40 dark:text-text-dark/30">
            <span id="sidebar-current-time">0:00</span>
            <span id="sidebar-total-time">0:00</span>
          </div>
        </div>

        <div class="flex items-center w-full h-9 rounded-lg overflow-hidden
                    bg-neutral-100/60 dark:bg-neutral-800/40
                    border border-border-light dark:border-border-dark
                    divide-x divide-border-light dark:divide-border-dark">
          
          <button id="sidebar-prev-btn" 
                  class="flex-1 h-full flex items-center justify-center 
                        text-text-light/40 dark:text-text-dark/30 hover:text-text-light/80 dark:hover:text-text-dark/80
                        hover:bg-neutral-900/3 dark:hover:bg-white/3
                        active:scale-95 transition-all duration-150 cursor-pointer" 
                  title="上一首">
            <Icon name="play-prev" class="w-3.5 h-3.5" />
          </button>
          
          <button id="sidebar-toggle-btn" 
                  class="flex-1 h-full flex items-center justify-center
                        text-text-light/70 dark:text-text-dark/70 hover:text-text-light dark:hover:text-text-dark
                        hover:bg-neutral-900/5 dark:hover:bg-white/5
                        active:scale-95 transition-all duration-150 cursor-pointer" 
                  title="播放/暂停">
            <Icon id="sidebar-play-icon" name="play" class="w-4 h-4" />
            <Icon id="sidebar-pause-icon" name="pause" class="w-4 h-4 hidden" />
          </button>
          
          <button id="sidebar-next-btn" 
                  class="flex-1 h-full flex items-center justify-center
                        text-text-light/40 dark:text-text-dark/30 hover:text-text-light/80 dark:hover:text-text-dark/80
                        hover:bg-neutral-900/3 dark:hover:bg-white/3
                        active:scale-95 transition-all duration-150 cursor-pointer" 
                  title="下一首">
            <Icon name="play-next" class="w-3.5 h-3.5" />
          </button>
        </div>

      </div>

      <div class="absolute right-[-6px] top-1/2 -translate-y-1/2 w-0 h-0 border-t-[6px] border-t-transparent border-b-[6px] border-b-transparent border-l-[6px] border-l-border-light dark:border-l-border-dark"></div>
      <div class="absolute right-[-5px] top-1/2 -translate-y-1/2 w-0 h-0 border-t-[5px] border-t-transparent border-b-[5px] border-b-transparent border-l-[5px] border-l-card-light dark:border-l-card-dark"></div>
    </div>
    <!-- 圆形黑胶唱片按钮 -->
    <div id="sidebar-btn-vinyl" class="w-10 h-10 rounded-full bg-card-light dark:bg-card-dark border border-border-light dark:border-border-dark flex items-center justify-center group-hover/bar:bg-primary-light/10 dark:group-hover/bar:bg-primary-dark/10 group-hover/bar:border-primary-light/30 dark:group-hover/bar:border-primary-dark/30 fluid-icon shadow-md hover:shadow-lg">
      <div class="w-[30px] h-[30px] rounded-full border border-black/5 bg-linear-to-tr from-neutral-900 via-neutral-800 to-neutral-950 p-[2px]">
        <img id="sidebar-btn-cover" src="/img/df-cover.webp" alt="音乐" class="w-full h-full object-cover rounded-full mix-blend-screen dark:mix-blend-normal" />
      </div>
    </div>
  </div>

  <!-- 返回顶部按钮 -->
  <div
    id="jump-to-bottom"
    class="flex items-center justify-end w-[180px] group/bar cursor-pointer opacity-0 transition-opacity duration-500 relative"
    aria-label="返回顶部"
  >
    <!-- 左侧提示信息框（在按钮左边） -->
    <div class="absolute right-12 px-3 py-1.5 rounded-lg bg-card-light dark:bg-card-dark border border-border-light dark:border-border-dark shadow-lg opacity-0 group-hover/bar:opacity-100 transition-all duration-300 pointer-events-none whitespace-nowrap translate-x-2 group-hover/bar:translate-x-0">
      <span class="text-sm font-medium text-text-light dark:text-text-dark">返回顶部</span>
      <!-- 小三角形指示器 - 指向右侧 -->
      <div class="absolute right-[-6px] top-1/2 -translate-y-1/2 w-0 h-0 border-t-[6px] border-t-transparent border-b-[6px] border-b-transparent border-l-[6px] border-l-border-light dark:border-l-border-dark"></div>
      <div class="absolute right-[-5px] top-1/2 -translate-y-1/2 w-0 h-0 border-t-[5px] border-t-transparent border-b-[5px] border-b-transparent border-l-[5px] border-l-card-light dark:border-l-card-dark"></div>
    </div>
    <!-- 圆形背景 + 向上箭头图标 -->
    <div class="w-10 h-10 rounded-full bg-card-light dark:bg-card-dark border border-border-light dark:border-border-dark flex items-center justify-center group-hover/bar:bg-primary-light/10 dark:group-hover/bar:bg-primary-dark/10 group-hover/bar:border-primary-light/30 dark:group-hover/bar:border-primary-dark/30 fluid-icon shadow-md hover:shadow-lg">
      <Icon name="chevron-up" class="w-5 h-5 text-text-light/70 dark:text-text-dark/70 group-hover/bar:text-primary-light dark:group-hover/bar:text-primary-dark transition-all duration-300" />
    </div>
  </div>
</div>

<style>
  /* JS 管理的面板激活状态 */
  #share-button.panel-active #share-panel,
  #reward-button.panel-active #reward-large-panel,
  #subscribe-button.panel-active #subscribe-panel,
  #music-button.panel-active #music-panel {
    opacity: 1 !important;
    pointer-events: auto !important;
    transform: scale(1) !important;
  }

  /* 当有面板激活时，强制隐藏其他面板（即使容器被 hover） */
  #sidebar-of-contents.has-active-panel #share-button:not(.panel-active) #share-panel,
  #sidebar-of-contents.has-active-panel #reward-button:not(.panel-active) #reward-large-panel,
  #sidebar-of-contents.has-active-panel #subscribe-button:not(.panel-active) #subscribe-panel,
  #sidebar-of-contents.has-active-panel #music-button:not(.panel-active) #music-panel {
    opacity: 0 !important;
    pointer-events: none !important;
    transform: scale(0.95) !important;
    transition-delay: 0s !important;
  }

  /* 音乐面板黑胶旋转 */
  #sidebar-vinyl.is-playing,
  #sidebar-btn-vinyl.is-playing {
    animation: vinyl-spin 8s linear infinite;
  }
  #sidebar-vinyl.is-paused,
  #sidebar-btn-vinyl.is-paused {
    animation: vinyl-spin 8s linear infinite;
    animation-play-state: paused;
  }
  @keyframes vinyl-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>

<script>
  import QRCode from 'qrcode';

  function initSidebarOfContents() {
    const sidebarContainer = document.getElementById('sidebar-of-contents');
    const backToTopButton = document.getElementById('back-to-top');
    const jumpToBottomButton = document.getElementById('jump-to-bottom');
    const jumpToCommentsButton = document.getElementById('jump-to-comments');

    // 获取本地图片路径
    const sidebarData = document.getElementById('sidebar-data');
    const localCoverImage = sidebarData?.getAttribute('data-df-about') || '';
    const avatarUrl = '/img/avatar.webp';

    if (!sidebarContainer || !backToTopButton || !jumpToBottomButton || !jumpToCommentsButton) {
      return;
    }

    // 预加载头像
    const preloadAvatar = () => {
      const preloadLink = document.createElement('link');
      preloadLink.rel = 'preload';
      preloadLink.as = 'image';
      preloadLink.href = avatarUrl;
      preloadLink.crossOrigin = 'anonymous';
      document.head.appendChild(preloadLink);
    };

    // 预加载 HeroImage
    const preloadHeroImage = () => {
      // 检查是否是 about 页面
      const isAboutPage = window.location.pathname === '/about' || window.location.pathname === '/about/';

      if (isAboutPage) {
        // about 页面使用本地图片
        const heroImageSrc = localCoverImage;

        const preloadLink = document.createElement('link');
        preloadLink.rel = 'preload';
        preloadLink.as = 'image';
        preloadLink.href = heroImageSrc;
        preloadLink.crossOrigin = 'anonymous';
        document.head.appendChild(preloadLink);
        return;
      }

      // 其他页面：尝试多种选择器提取 HeroImage URL
      const selectors = [
        'article div.bg-cover.bg-center',
        'article div[class*="bg-cover"]',
        'div.bg-cover.bg-center',
        'article > div > div.bg-cover'
      ];

      for (const selector of selectors) {
        const heroImageDiv = document.querySelector(selector);
        if (heroImageDiv) {
          const bgImage = window.getComputedStyle(heroImageDiv).backgroundImage;

          if (bgImage && bgImage !== 'none') {
            const urlMatch = bgImage.match(/url\(['"]?([^'"]+)['"]?\)/);
            if (urlMatch) {
              const heroImageSrc = urlMatch[1];

              // 动态创建 preload 标签并插入到 head
              const preloadLink = document.createElement('link');
              preloadLink.rel = 'preload';
              preloadLink.as = 'image';
              preloadLink.href = heroImageSrc;
              preloadLink.crossOrigin = 'anonymous';
              document.head.appendChild(preloadLink);
              break;
            }
          }
        }
      }
    };

    // 页面加载时立即预加载头像和 HeroImage
    preloadAvatar();
    preloadHeroImage();

    // 创建一个仅包含返回顶部和直达底部的容器用于显示/隐藏
    const scrollButtons = [jumpToBottomButton];

    // 显示/隐藏滚动按钮（返回上一页和评论区按钮始终可见）
    const toggleScrollButtons = () => {
      const scrollY = window.pageYOffset;

      // 当滚动超过 200px 时显示返回顶部按钮
      if (scrollY > 200) {
        scrollButtons.forEach(button => {
          button.classList.remove('opacity-0');
          button.classList.add('opacity-100');
        });
      } else {
        scrollButtons.forEach(button => {
          button.classList.remove('opacity-100');
          button.classList.add('opacity-0');
        });
      }
    };

    // 返回上一页功能
    const goBack = () => {
      if (window.history.length > 1) {
        window.history.back();
      } else {
        window.location.href = '/';
      }
    };

    // 返回顶部功能
    const scrollToTop = () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth',
      });
    };

    // 初始状态
    toggleScrollButtons();
    // 评论区按钮已经通过 CSS 设置为 opacity-100，不需要额外设置

    // 监听滚动事件
    let scrollTimeout: ReturnType<typeof setTimeout> | undefined;
    window.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(toggleScrollButtons, 100);
    }, { passive: true });

    // 直达评论区功能
    const scrollToComments = () => {
      const commentsSection = document.getElementById('comments-section');
      if (commentsSection) {
        const commentsRect = commentsSection.getBoundingClientRect();
        const scrollTop = window.pageYOffset + commentsRect.top - 100;
        window.scrollTo({
          top: scrollTop,
          behavior: 'smooth',
        });
      }
    };

    // 生成海报功能
    const generatePoster = async () => {
      const downloadBtn = document.getElementById('download-poster-btn') as HTMLButtonElement | null;
      const posterPreview = document.getElementById('poster-preview');
      const posterImage = document.getElementById('poster-image') as HTMLImageElement | null;

      if (!downloadBtn || !posterPreview || !posterImage) return;

      try {
        // 获取当前页面信息
        const pageTitle = document.querySelector('[data-article-title]')?.textContent || document.querySelector('h1')?.textContent || document.title;
        const pageDescription = (document.querySelector('meta[name="description"]') as HTMLMetaElement)?.content || '分享这篇文章';
        const pageUrl = window.location.href;

        // 获取 heroImage（从 background-image 样式中提取）
        let heroImageSrc = '';

        // 检查是否是 about 页面，如果是则使用本地图片
        const isAboutPage = window.location.pathname === '/about' || window.location.pathname === '/about/';

        if (isAboutPage) {
          heroImageSrc = localCoverImage;
        } else {
          // 尝试多种选择器
          const selectors = [
            'article div.bg-cover.bg-center',
            'article div[class*="bg-cover"]',
            'div.bg-cover.bg-center',
            'article > div > div.bg-cover'
          ];

          for (const selector of selectors) {
            const heroImageDiv = document.querySelector(selector);
            if (heroImageDiv) {
              const bgImage = window.getComputedStyle(heroImageDiv).backgroundImage;

              if (bgImage && bgImage !== 'none') {
                const urlMatch = bgImage.match(/url\(['"]?([^'"]+)['"]?\)/);
                if (urlMatch) {
                  heroImageSrc = urlMatch[1];
                  break;
                }
              }
            }
          }
        }

        // 创建 Canvas - 固定尺寸 750x1000
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        if (!ctx) {
          throw new Error('无法获取 Canvas 上下文');
        }
        const posterWidth = 750;
        const posterHeight = 1000;
        canvas.width = posterWidth;
        canvas.height = posterHeight;

        // 背景色
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, posterWidth, posterHeight);

        // 绘制 heroImage（如果存在）- 使用源矩形裁剪，避免 clip
        if (heroImageSrc) {
          try {
            const img = new Image();

            // 关键：必须与 preload 标签中的 crossorigin 对应
            img.crossOrigin = 'anonymous';

            // 赋值 src，由于已经预加载，这里几乎不产生网络开销
            img.src = heroImageSrc;

            // 使用 decode() 代替 Promise + onload
            // 它专门用于确保图片像素已解码完成，且不阻塞主线程
            await img.decode();

            // 目标区域 - 占据45%的高度
            const targetWidth = posterWidth;
            const targetHeight = 450; // 45% of 1000px

            const imgRatio = img.width / img.height;
            const targetRatio = targetWidth / targetHeight;

            let sx, sy, sWidth, sHeight;

            if (imgRatio > targetRatio) {
              // 图片更宽，裁剪左右两侧
              sHeight = img.height;
              sWidth = sHeight * targetRatio;
              sx = (img.width - sWidth) / 2;
              sy = 0;
            } else {
              // 图片更高，裁剪上下两侧
              sWidth = img.width;
              sHeight = sWidth / targetRatio;
              sx = 0;
              sy = (img.height - sHeight) / 2;
            }

            // 使用 drawImage 的 9 参数版本：源矩形 + 目标矩形
            ctx.drawImage(img, sx, sy, sWidth, sHeight, 0, 0, targetWidth, targetHeight);
          } catch (err) {
            // HeroImage 加载失败
          }
        }

        // 绘制标题 - 左对齐，使用与描述相同的maxWidth
        ctx.fillStyle = '#1a1a1a';
        ctx.font = 'bold 48px sans-serif';
        ctx.textAlign = 'left'; // 改为左对齐
        ctx.textBaseline = 'top';
        const titleY = heroImageSrc ? 490 : 80; // 图片后留40px边距（450+40）
        const contentMaxWidth = posterWidth - 80; // 670px，与分隔线和描述宽度一致
        const titleLines = wrapText(ctx, pageTitle, 40, titleY, contentMaxWidth, 60);

        // 绘制描述 - 左对齐，maxWidth与分隔线宽度一致
        ctx.fillStyle = '#666666';
        ctx.font = '30px sans-serif';
        ctx.textAlign = 'left'; // 改为左对齐
        const descY = titleY + (titleLines * 60) + 20; // 根据标题实际行数计算位置
        wrapText(ctx, pageDescription, 40, descY, contentMaxWidth, 40);

        // 绘制分隔线 - 在二维码区域上方，与标题宽度一致
        ctx.strokeStyle = '#e0e0e0';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.moveTo(40, 800); // 从左边距40px开始，与标题对齐
        ctx.lineTo(posterWidth - 40, 800); // 到右边距40px结束，与标题对齐
        ctx.stroke();

                // 加载并绘制圆形头像和作者信息
        const avatarUrl = '/img/avatar.webp';

        const avatarSize = 110; 
        const avatarX = 40; 
        const avatarY = 890; 

        try {
          const avatarImg = new Image();
          
          // 关键：必须与 preload 标签中的 crossorigin 对应
          avatarImg.crossOrigin = 'anonymous'; 
          
          // 赋值 src，由于已经预加载，这里几乎不产生网络开销
          avatarImg.src = avatarUrl;

          // 使用更高级的 decode() 代替 Promise + onload
          // 它专门用于确保图片像素已解码完成，且不阻塞主线程
          await avatarImg.decode();

          // 绘制圆形头像
          ctx.save();
          ctx.beginPath();
          // 注意：arc 的中心点坐标计算
          ctx.arc(avatarX + avatarSize / 2, avatarY, avatarSize / 2, 0, Math.PI * 2);
          ctx.closePath();
          ctx.clip();
          
          // 绘制图片：Y 轴由于 arc 中心在 avatarY，绘图起点需向上偏移半径
          ctx.drawImage(avatarImg, avatarX, avatarY - avatarSize / 2, avatarSize, avatarSize);

          ctx.restore();
        } catch (err) {
          // 头像加载失败
        }

        // 绘制作者名称 "波罗歌"（无论头像是否加载成功都绘制）
        ctx.fillStyle = '#1a1a1a';
        ctx.font = 'bold 36px sans-serif'; // 进一步增大字体
        ctx.textAlign = 'left';
        ctx.textBaseline = 'middle';
        ctx.fillText('波罗歌', avatarX + avatarSize + 20, avatarY - 22);

        // 绘制签名 "一知半解，从一而终"
        ctx.fillStyle = '#666666';
        ctx.font = '24px sans-serif'; // 进一步增大字体
        ctx.textAlign = 'left';
        ctx.textBaseline = 'middle';
        ctx.fillText('一知半解，从一而终', avatarX + avatarSize + 20, avatarY + 22);

        // 生成二维码（使用本地 qrcode 库）
        const qrSize = 110; // 调整为110px

        try {
          // 使用本地 qrcode 库生成二维码
          const qrDataUrl = await QRCode.toDataURL(pageUrl, {
            width: qrSize,
            margin: 1,
            color: {
              dark: '#000000',
              light: '#FFFFFF'
            }
          });

          // 将二维码绘制到 canvas
          const qrImg = new Image();
          await new Promise((resolve, reject) => {
            qrImg.onload = resolve;
            qrImg.onerror = reject;
            qrImg.src = qrDataUrl;
          });

          const qrX = posterWidth - 180; // 靠右放置，留出左侧空间给头像和文字
          const qrY = 825; // 分隔线下方25px
          ctx.drawImage(qrImg, qrX, qrY, qrSize, qrSize);

          // 二维码下方文字
          ctx.fillStyle = '#999999';
          ctx.font = '18px sans-serif';
          ctx.textAlign = 'center';
          ctx.fillText('扫码查看原文', qrX + qrSize / 2, 960); // 文字位置相应调整
        } catch (err) {
          // 二维码生成失败
        }

        // 将 Canvas 转换为图片
        const dataUrl = canvas.toDataURL('image/png');
        posterImage.src = dataUrl;

        // 保存 dataUrl 供下载使用
        downloadBtn.dataset.posterUrl = dataUrl;
      } catch (error) {
        // 生成海报失败
      }
    };

    // 文字换行辅助函数 - 返回实际绘制的行数
    function wrapText(ctx: CanvasRenderingContext2D, text: string, x: number, y: number, maxWidth: number, lineHeight: number): number {
      const lines = [];
      let currentLine = '';
      const maxLines = 3;

      // 第一步：将文本分割成行
      for (let i = 0; i < text.length; i++) {
        const char = text[i];
        const testLine = currentLine + char;
        const testWidth = ctx.measureText(testLine).width;

        if (testWidth > maxWidth && currentLine.length > 0) {
          // 当前行已满，保存当前行，开始新行
          lines.push(currentLine);
          currentLine = char; // 当前字符作为新行的第一个字符
        } else {
          // 继续添加到当前行
          currentLine = testLine;
        }
      }

      // 添加最后一行
      if (currentLine.length > 0) {
        lines.push(currentLine);
      }

      // 第二步：绘制行（最多3行）
      for (let i = 0; i < Math.min(lines.length, maxLines); i++) {
        let lineText = lines[i];

        // 如果是第3行且还有更多内容，添加省略号
        if (i === maxLines - 1 && lines.length > maxLines) {
          const ellipsis = '...';
          // 确保省略号能放得下
          while (ctx.measureText(lineText + ellipsis).width > maxWidth && lineText.length > 1) {
            lineText = lineText.slice(0, -1);
          }
          lineText += ellipsis;
        }

        ctx.fillText(lineText, x, y + i * lineHeight);
      }

      // 返回实际绘制的行数
      return Math.min(lines.length, maxLines);
    }

    // 下载海报
    const downloadPoster = () => {
      const downloadBtn = document.getElementById('download-poster-btn') as HTMLButtonElement | null;
      if (!downloadBtn || !downloadBtn.dataset.posterUrl) return;

      const originalHtml = downloadBtn.innerHTML;

      try {
        const link = document.createElement('a');
        link.download = 'poster.png';
        link.href = downloadBtn.dataset.posterUrl;
        link.click();

        // 下载成功反馈
        downloadBtn.innerHTML = '😋下载成功';

        setTimeout(() => {
          downloadBtn.innerHTML = originalHtml;
        }, 2000);
      } catch (error) {
        // 下载失败
      }
    };

    // 监听点击事件
    backToTopButton.addEventListener('click', goBack);
    jumpToBottomButton.addEventListener('click', scrollToTop);
    jumpToCommentsButton.addEventListener('click', scrollToComments);

    // 复制链接功能
    const copyLink = () => {
      const copyLinkBtn = document.getElementById('copy-link-btn') as HTMLButtonElement | null;
      if (!copyLinkBtn) return;

      const pageUrl = window.location.href;
      const originalHtml = copyLinkBtn.innerHTML;

      navigator.clipboard.writeText(pageUrl).then(() => {
        // 复制成功反馈
        copyLinkBtn.innerHTML = '🥳已复制';

        setTimeout(() => {
          copyLinkBtn.innerHTML = originalHtml;
        }, 2000);
      }).catch((_err) => {
        // 复制失败
        setTimeout(() => {
          copyLinkBtn.innerHTML = originalHtml;
        }, 2000);
      });
    };

    // 下载海报按钮
    const downloadPosterBtn = document.getElementById('download-poster-btn');
    if (downloadPosterBtn) {
      downloadPosterBtn.addEventListener('click', downloadPoster);
    }

    // 复制链接按钮
    const copyLinkBtn = document.getElementById('copy-link-btn');
    if (copyLinkBtn) {
      copyLinkBtn.addEventListener('click', copyLink);
    }

    // RSS复制功能
    const copyRssLink = () => {
      const rssCopyBtn = document.getElementById('rss-copy-btn') as HTMLButtonElement | null;
      const rssTextSpan = document.getElementById('rss-copy-text') as HTMLSpanElement | null;
      if (!rssCopyBtn || !rssTextSpan) return;

      const rssUrl = rssCopyBtn.getAttribute('data-rss-url') || 'https://log.1k.ink/rss.xml';
      const originalText = rssTextSpan.textContent;

      navigator.clipboard.writeText(rssUrl).then(() => {
        // 复制成功反馈
        rssTextSpan.textContent = '已复制 😋';

        setTimeout(() => {
          rssTextSpan.textContent = originalText || '复制链接';
        }, 2000);
      }).catch((_err) => {
        // RSS链接复制失败
        setTimeout(() => {
          rssTextSpan.textContent = originalText || '复制链接';
        }, 2000);
      });
    };

    // RSS复制按钮
    const rssCopyBtn = document.getElementById('rss-copy-btn');
    if (rssCopyBtn) {
      rssCopyBtn.addEventListener('click', copyRssLink);
    }

    // 自动生成海报
    generatePoster();

    // 面板互斥：同一时间只允许一个面板打开
    const panelContainerIds = ['share-button', 'reward-button', 'subscribe-button', 'music-button'];
    const panelContainers = panelContainerIds.map(id => document.getElementById(id)).filter(Boolean) as HTMLElement[];

    let activePanelId: string | null = null;
    let panelDeactivateTimeout: ReturnType<typeof setTimeout> | undefined;

    panelContainers.forEach(container => {
      container.addEventListener('mouseenter', () => {
        clearTimeout(panelDeactivateTimeout);

        // 关闭之前激活的面板
        if (activePanelId && activePanelId !== container.id) {
          document.getElementById(activePanelId)?.classList.remove('panel-active');
        }

        // 激活当前面板
        activePanelId = container.id;
        container.classList.add('panel-active');
        sidebarContainer.classList.add('has-active-panel');
      });

      container.addEventListener('mouseleave', () => {
        panelDeactivateTimeout = setTimeout(() => {
          container.classList.remove('panel-active');
          if (activePanelId === container.id) {
            activePanelId = null;
            sidebarContainer.classList.remove('has-active-panel');
          }
        }, 50);
      });
    });

    // 赞赏面板 Tab 切换
    const tabs = document.querySelectorAll('.reward-tab') as NodeListOf<HTMLButtonElement>;
    const qrs = document.querySelectorAll('.reward-qr') as NodeListOf<HTMLDivElement>;

    tabs.forEach((tab) => {
      tab.addEventListener('click', (e: Event) => {
        const target = e.currentTarget as HTMLButtonElement;
        const targetId = target.id;

        // 1. 重置所有 Tab 样式
        tabs.forEach(t => {
          t.classList.remove('bg-white', 'dark:bg-neutral-800', 'shadow-sm', 'text-text-light', 'dark:text-text-dark');
          t.classList.add('text-text-light/50', 'dark:text-text-dark/40');
        });

        // 2. 高亮当前选中 Tab
        target.classList.add('bg-white', 'dark:bg-neutral-800', 'shadow-sm', 'text-text-light', 'dark:text-text-dark');
        target.classList.remove('text-text-light/50', 'dark:text-text-dark/40');

        // 3. 切换二维码显示逻辑
        const targetQrId = targetId === 'tab-wechat' ? 'qr-wechat' : 'qr-alipay';

        qrs.forEach(qr => {
          if (qr.id === targetQrId) {
            qr.classList.replace('opacity-0', 'opacity-100');
            qr.classList.replace('scale-95', 'scale-100');
            qr.style.pointerEvents = 'auto';
          } else {
            qr.classList.replace('opacity-100', 'opacity-0');
            qr.classList.replace('scale-100', 'scale-95');
            qr.style.pointerEvents = 'none';
          }
        });
      });
    });

    // 音乐面板初始化
    import('../scripts/musicPlayer').then(({ initPlayerCore, ensureState, startPeriodicUpdate, formatTime, initProgressBarClick, registerUIUpdater, registerProgressUpdater }) => {
      function updateMusicPanel() {
        const ap = (window as any).musicPlayerState?.ap;
        const songEl = document.getElementById('sidebar-song');
        const artistEl = document.getElementById('sidebar-artist');
        const coverEl = document.getElementById('sidebar-cover') as HTMLImageElement | null;
        const playIcon = document.getElementById('sidebar-play-icon');
        const pauseIcon = document.getElementById('sidebar-pause-icon');
        const vinyl = document.getElementById('sidebar-vinyl');
        const btnVinyl = document.getElementById('sidebar-btn-vinyl');
        const btnCover = document.getElementById('sidebar-btn-cover') as HTMLImageElement | null;
        const progressBar = document.getElementById('sidebar-progress-bar');
        const currentTimeEl = document.getElementById('sidebar-current-time');
        const totalTimeEl = document.getElementById('sidebar-total-time');

        if (!ap) return;

        const isPlaying = !ap.audio.paused;
        const currentSong = ap.list.audios[ap.list.index];

        if (currentSong) {
          if (songEl) songEl.textContent = currentSong.name;
          if (artistEl) artistEl.textContent = currentSong.artist;
          if (coverEl && currentSong.cover && coverEl.src !== currentSong.cover) {
            coverEl.src = currentSong.cover;
          }
          if (btnCover && currentSong.cover && btnCover.src !== currentSong.cover) {
            btnCover.src = currentSong.cover;
          }
        }

        // 更新进度条和时间
        if (ap.audio.duration) {
          const percent = (ap.audio.currentTime / ap.audio.duration) * 100;
          if (progressBar) progressBar.style.width = `${percent}%`;
          if (currentTimeEl) currentTimeEl.textContent = formatTime(ap.audio.currentTime);
          if (totalTimeEl) totalTimeEl.textContent = formatTime(ap.audio.duration);
        }

        if (isPlaying) {
          playIcon?.classList.add('hidden');
          pauseIcon?.classList.remove('hidden');
          vinyl?.classList.remove('is-paused');
          vinyl?.classList.add('is-playing');
          btnVinyl?.classList.remove('is-paused');
          btnVinyl?.classList.add('is-playing');
        } else {
          playIcon?.classList.remove('hidden');
          pauseIcon?.classList.add('hidden');
          vinyl?.classList.remove('is-playing');
          vinyl?.classList.add('is-paused');
          btnVinyl?.classList.remove('is-playing');
          btnVinyl?.classList.add('is-paused');
        }
      }

      async function initMusicPanel() {
        ensureState();

        if (!(window as any).musicPlayerState.isInitialized) {
          await initPlayerCore('hidden-aplayer-sidebar');
        }

        registerUIUpdater(updateMusicPanel);
        registerProgressUpdater(updateMusicPanel);

        updateMusicPanel();
        startPeriodicUpdate();
      }

      // 控制按钮绑定
      document.getElementById('sidebar-prev-btn')?.addEventListener('click', () => (window as any).playPrev?.());
      document.getElementById('sidebar-toggle-btn')?.addEventListener('click', () => (window as any).togglePlay?.());
      document.getElementById('sidebar-next-btn')?.addEventListener('click', () => (window as any).playNext?.());

      // 进度条点击/拖拽
      initProgressBarClick('sidebar-progress-bar');

      initMusicPanel();
    });
  }

  // 页面加载时初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(initSidebarOfContents, 100);
    });
  } else {
    setTimeout(initSidebarOfContents, 100);
  }

  // 监听 Astro 页面转换
  document.addEventListener('astro:after-swap', () => {
    setTimeout(initSidebarOfContents, 100);
  });
</script>
