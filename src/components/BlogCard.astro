---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { calculateReadingTime } from '../utils/readingTime';
const defaultCover = '/img/df-cover.webp';

interface Props {
  post: CollectionEntry<'post'>;
  key?: string;
}

const { post } = Astro.props;
const { title, description, pubDate, heroImage, category, tags } = post.data;
const originalFileName = post.id.toLowerCase();
const displayImage = heroImage || defaultCover;
const readingTime = calculateReadingTime(post.body || '');

---
<article class="group relative bg-card-light dark:bg-card-dark rounded-3xl shadow-sm hover:-translate-y-2 hover:shadow-2xl transition-all duration-500 overflow-hidden border border-transparent hover:border-border-light dark:hover:border-border-dark">
  <div class="relative flex flex-col justify-between">
    

    <a href={`/p/${originalFileName}`} class="relative overflow-hidden bg-hero-light dark:bg-hero-dark block h-52 w-full" aria-label={title}>
      <div
        class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110"
        style={`background-image: url('${displayImage}');`}
      ></div>
    </a>

    <div class="relative p-6 flex flex-col items-start">
      
      {/* 2.1 元信息行（两端对撞） */}
      <div class="flex flex-row items-center justify-between w-full text-[11px] font-medium tracking-wide text-text-light/40 dark:text-text-dark/40 mb-2.5 select-none">
        {/* 左侧技术轴 */}
        <div class="flex items-center gap-2">
          {/* 分类 */}
          <div class="flex items-center gap-1.5 uppercase">
            <span class="text-zinc-300 dark:text-zinc-600 font-bold">#</span>
            <span class="tracking-widest">{category}</span>
          </div>

          {/* 标签群 */}
          {tags && tags.length > 0 && (
            <div class="hidden md:flex items-center gap-2">
              <span class="text-[9px] opacity-30 font-light">/</span>
              <div class="flex items-center gap-1.5 opacity-85">
                {tags.slice(0, 3).map((tag: string, index: number) => (
                  <div class="flex items-center gap-1.5 whitespace-nowrap">
                    {index > 0 && <span class="text-[9px] opacity-30 font-light">/</span>}
                    <span>{tag}</span>
                  </div>
                ))}
              </div>
            </div>
          )}
          
          {/* 阅读时长 */}
          <span class="text-[9px] opacity-30 font-light">/</span>
          <span class="tracking-wide">{readingTime} 分钟</span>
        </div>

        {/* 右侧绝对日期 */}
        <div class="flex items-center tracking-wide opacity-85 pr-2">
          <FormattedDate date={pubDate} />
        </div>
      </div>


      <h3 class="text-2xl font-bold mb-2.5 line-clamp-1">
        <a
          href={`/p/${originalFileName}`}
          class="text-text-light dark:text-text-dark hover:text-primary-light dark:hover:text-primary-dark transition-colors duration-300"
        >
          {title}
        </a>
      </h3>


      <p class="text-sm text-text-light/60 dark:text-text-dark/55 line-clamp-1">
        {description}
      </p>

    </div>
  </div>
</article>