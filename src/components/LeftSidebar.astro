---
import { getCollection, getEntry } from 'astro:content';

interface Rating {
  source: 'douban' | 'bangumi';
  score: number;
}

interface Link {
  source: 'douban' | 'bangumi';
  url: string;
}

interface WatchingItem {
  title: string;
  year: number;
  cover: string;
  comment: string;
  type: string;
  country?: string;
  ratings?: Rating[];
  links?: Link[];
}

const posts = await getCollection('post', ({ data }) => !data.draft && !data.friends && !data.friendGroups && !data.moments);

const defaultWatching: WatchingItem[] = [
  {
    title: '虫师',
    year: 2005,
    cover: '/img/df-cover.webp',
    comment: '远山如雾',
    type: '动画',
    ratings: [{ source: 'douban', score: 9.4 }],
    links: [{ source: 'douban', url: 'https://movie.douban.com/subject/1800597/' }],
  },
  {
    title: '无头骑士异闻录',
    year: 2010,
    cover: '/img/df-cover.webp',
    comment: '这里是池袋',
    type: '动画',
    ratings: [{ source: 'douban', score: 8.8 }],
    links: [{ source: 'douban', url: 'https://movie.douban.com/subject/4291876/' }],
  },
];

let watchingList: WatchingItem[] = defaultWatching;
try {
  const watchingData = await getEntry('post', 'watching');
  if (watchingData && watchingData.data.watching) {
    watchingList = watchingData.data.watching as WatchingItem[];
  }
} catch (error) {
  console.log('Using default watching data');
}

const ratingIcons: Record<string, string> = {
  douban: '/img/douban.ico',
  bangumi: '/img/bangumi.ico',
};


const categories = posts.reduce((acc, post) => {
  const category = post.data.category;
  if (category) {
    acc[category] = (acc[category] || 0) + 1;
  }
  return acc;
}, {} as Record<string, number>);

const sortedCategories = Object.entries(categories).sort((a, b) => b[1] - a[1]);
import { Icon } from 'astro-icon/components';
---

<aside class="hidden md:block w-[272px] space-y-6">
  <!-- 个人信息卡片 -->
  <div class="p-4 h-[300px] bg-primary-light dark:bg-primary-dark rounded-3xl shadow-sm fluid-card matrix-card relative overflow-hidden border border-transparent hover:border-border-light dark:hover:border-border-dark">
    <!-- 顶部：醉后不知天在水 文本 -->
    <div class="absolute top-4 left-0 right-0 flex justify-center">
      <div class="px-3 py-1 bg-white/20 dark:bg-black/50 rounded-full greeting-container">
        <span class="text-sm font-medium text-white greeting-text" style="will-change: transform, opacity; text-rendering: optimizeSpeed;">醉后不知天在水</span>
      </div>
    </div>
    <!-- 中间：头像 -->
    <div class="absolute top-0 left-0 right-0 bottom-0 flex justify-center items-center pt-12 pb-16">
      <div class="relative avatar-container">
        <div class="avatar-mouse-wrapper transform-gpu relative">
          
          <img
            src="/img/avatar.webp"
            alt="博主头像"
            class="w-[115px] h-[115px] rounded-full object-cover ring-4 ring-white/50 dark:ring-black/50 shadow-lg avatar-image transform-gpu cursor-pointer"
          />

          <div class="static-emojis-pool absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none z-9999">
            <img src="/img/emoji/cool.webp"  class="static-emoji" data-file="cool"  alt="fluent-3d-emoji" />
            <img src="/img/emoji/cat.webp"   class="static-emoji" data-file="cat"   alt="fluent-3d-emoji" />
            <img src="/img/emoji/yummy.webp" class="static-emoji" data-file="yummy" alt="fluent-3d-emoji" />
            <img src="/img/emoji/cry.webp"   class="static-emoji" data-file="cry"   alt="fluent-3d-emoji" />
            <img src="/img/emoji/nerd.webp"  class="static-emoji" data-file="nerd"  alt="fluent-3d-emoji" />
            <img src="/img/emoji/laugh.webp" class="static-emoji" data-file="laugh" alt="fluent-3d-emoji" />
          </div>

        </div>
      </div>
    </div>
    <!-- 底部：信息区 -->
    <div class="absolute bottom-4 left-4 right-4 flex justify-between items-center">
      <!-- 左侧：博主信息容器 -->
      <a href="/about" class="text-container block hover:opacity-85 fluid-link">
        <h2 class="text-xl font-bold text-white dark:text-black mb-1 matrix-text" data-text="波罗歌">波罗歌</h2>
        <p class="text-xs text-white dark:text-black/90 opacity-60 matrix-text" data-text="万维网中潮汛来">万维网中潮汛来</p>
      </a>

      <!-- 右侧：社交图标容器 -->
      <div class="icons-container flex space-x-2">
        <a href="https://github.com/LogLInk1K" target="_blank" rel="noopener noreferrer" 
           class="text-white hover:text-white fluid-btn hover:scale-110 relative group w-10 h-10 rounded-full bg-white/20 dark:bg-black/50 hover:bg-white/30 dark:hover:bg-black/70 flex items-center justify-center">
          <span class="sr-only">GitHub</span>
          <Icon name="github" class="w-5 h-5" aria-hidden="true" />
          <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 px-2 py-1 bg-white text-black dark:bg-black dark:text-white text-sm rounded-lg shadow-md opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 pointer-events-none whitespace-nowrap">
            GitHub
          </div>
        </a>
        <a href="https://space.bilibili.com/12787362" target="_blank" rel="noopener noreferrer" 
           class="text-white hover:text-white fluid-btn hover:scale-110 relative group w-10 h-10 rounded-full bg-white/20 dark:bg-black/50 hover:bg-white/30 dark:hover:bg-black/70 flex items-center justify-center">
          <span class="sr-only">Bilibili</span>
          <Icon name="bilibili" class="w-5 h-5" aria-hidden="true" />
          <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 px-2 py-1 bg-white text-black dark:bg-black dark:text-white text-sm rounded-lg shadow-md opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 pointer-events-none whitespace-nowrap">
            Bilibili
          </div>
        </a>
      </div>
    </div>  
  </div>

  <!-- 音乐卡片 -->
  <div transition:persist="left-sidebar-music" class="p-6 glass-card glass-card-dark">

    <div class="absolute -right-10 -top-10 w-32 h-32 bg-primary-light/10 dark:bg-primary-dark/10 rounded-full blur-3xl pointer-events-none group-hover/music:bg-primary-light/20 dark:group-hover/music:bg-primary-dark/20 transition-all duration-500"></div>

    <div class="absolute right-6 top-6 z-20">
      <div id="playing-indicator" class="flex items-center gap-[3px] opacity-0 h-3.5 transition-opacity duration-300 pointer-events-none">
        <div class="w-[2.5px] h-[80%] bg-primary-light dark:bg-primary-dark rounded-full bar-anim" style="--delay: -0.8s"></div>
        
        <div class="w-[2.5px] h-[90%] bg-primary-light/85 dark:bg-primary-dark/85 rounded-full bar-anim" style="--delay: -0.6s"></div>
        
        <div class="w-[2.5px] h-full bg-primary-light/65 dark:bg-primary-dark/65 rounded-full bar-anim" style="--delay: -0.4s"></div>
        
        <div class="w-[2.5px] h-full bg-primary-light/45 dark:bg-primary-dark/45 rounded-full bar-anim" style="--delay: -0.2s;--max-scale: 0.7;"></div>
      </div>
    </div>

    <div class="music-card-content relative z-10 flex flex-col gap-5 pt-2">
      <div class="flex items-center gap-5">
        
        <div class="relative w-20 h-20 shrink-0">
          <div class="vinyl-record flex items-center justify-center shadow-lg group-hover/music:scale-105 transition-transform duration-500">
            <img
              src="/img/df-cover.webp"
              alt="歌单封面"
              class="object-cover rounded-full relative z-10 transition-opacity duration-500 border border-black/20"
              style="width: 48px; height: 48px;"
              id="playlist-cover"
            />
          </div>
        </div>

        <div class="flex-1 min-w-0 flex flex-col gap-1 pl-0.5">
          <a href="https://music.163.com/playlist?id=2732533345" target="_blank" rel="noopener noreferrer" class="block group/title leading-none">
            <h4 id="playlist-name" class="text-base font-black text-neutral-800 dark:text-neutral-100 tracking-tight truncate group-hover/title:text-primary-light dark:group-hover/title:text-primary-dark transition-colors cursor-pointer">
              网易云歌单
            </h4>
          </a>
          
          <p class="text-[11px]  font-bold text-dim tracking-wider leading-none mt-0.5" id="playlist-count">
            加载中...
          </p>
          
        <div class="flex items-center gap-2 mt-1 leading-none">
            <span class="flex h-1.5 w-1.5 relative shrink-0">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-light dark:bg-primary-dark opacity-75"></span>
              <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-primary-light dark:bg-primary-dark"></span>
            </span>
            
            <p 
              class="text-xs font-bold text-primary-light/85 dark:text-primary-dark/90 truncate tracking-wide" 
              id="current-song"
            >
              未播放
            </p>
          </div>
        </div>

      </div>

      <div class="flex flex-col gap-4 mt-1">
        
        <div class="space-y-1.5 group/progress cursor-pointer">
          <div class="h-1 w-full bg-zinc-200/60 dark:bg-zinc-800/80 rounded-full transition-all duration-300 relative">
            
            <div 
              id="progress-bar" 
              class="h-full bg-primary-light dark:bg-primary-dark rounded-full transition-all duration-100 relative" 
              style="width: 0%"
            >
              <div class="absolute inset-0 bg-linear-to-r from-black/10 via-transparent to-white/40 dark:from-black/20 dark:to-white/20 rounded-full"></div>
              
              <div class="absolute -right-1 top-1/2 -translate-y-1/2 w-2 h-2 bg-white dark:bg-zinc-100 rounded-full shadow-[0_1px_3px_rgba(0,0,0,0.3)] scale-0 group-hover/progress:scale-100 transition-transform duration-200 ease-out z-10"></div>
            </div>

          </div>
          <div class="flex justify-between text-[10px]  font-bold tracking-wider text-dim">
            <span id="current-time">0:00</span>
            <span id="total-time">0:00</span>
          </div>
        </div>

        <div class="flex items-center justify-center gap-8 text-neutral-400 dark:text-neutral-500">
          <button onclick="playPrev()" class="p-1 hover:text-neutral-800 dark:hover:text-white fluid-link cursor-pointer active:scale-90 flex items-center justify-center" title="上一首">
            <Icon name="play-prev" class="w-5 h-5" />
          </button>
          
          <button onclick="togglePlay()" class="p-1 text-neutral-700 dark:text-neutral-300 accent-hover fluid-link cursor-pointer active:scale-95 flex items-center justify-center group/playbtn" title="播放/暂停">
            <Icon id="control-play-icon" name="play" class="w-6 h-6 transition-transform group-hover/playbtn:scale-105" />
            <Icon id="control-pause-icon" name="pause" class="w-6 h-6 hidden transition-transform group-hover/playbtn:scale-105" />
          </button>
          
          <button onclick="playNext()" class="p-1 hover:text-neutral-800 dark:hover:text-white fluid-link cursor-pointer active:scale-90 flex items-center justify-center" title="下一首">
            <Icon name="play-next" class="w-5 h-5" />
          </button>
        </div>

      </div>
    </div>

    <div id="hidden-aplayer" style="display: none;"></div>
  </div>

  <!-- 分类卡片 -->
  <div transition:persist="left-sidebar-categories" class="pt-5 px-5 pb-4 glass-card glass-card-dark">
    

  <div class="flex items-center justify-between px-1 pt-0.5 pb-4 select-none">
      
      <h3 class="text-base font-bold text-text-light dark:text-text-dark tracking-[0.2em]">
        分类
      </h3>
      
      <a 
        href="/categories" 
        title="全部分类"
        class="grid grid-cols-2 gap-0.5 transform -translate-y-px p-1.5 -m-1.5 rounded-lg hover:bg-black/3 dark:hover:bg-white/5 transition-all duration-500 ease-out group/icon cursor-pointer hover:rotate-90"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 dark:bg-yellow-500/80 shadow-[0_0_8px_rgba(99,102,241,0.6)] transition-all duration-500 group-hover/card:scale-110 group-hover/card:shadow-[0_0_12px_rgba(99,102,241,0.9)]"></span>
        
        <span class="w-1.5 h-1.5 rounded-full bg-zinc-300 dark:bg-zinc-700 group-hover/icon:bg-zinc-400 dark:group-hover/icon:bg-zinc-500 transition-colors duration-300"></span>
        <span class="w-1.5 h-1.5 rounded-full bg-zinc-300 dark:bg-zinc-700 group-hover/icon:bg-zinc-400 dark:group-hover/icon:bg-zinc-500 transition-colors duration-300"></span>
        <span class="w-1.5 h-1.5 rounded-full bg-zinc-200 dark:bg-zinc-800 group-hover/icon:bg-zinc-300 dark:group-hover/icon:bg-zinc-600 transition-colors duration-300"></span>
      </a>

  </div>
    
    <ul class="space-y-0.5">
      {sortedCategories.map(([category, count]) => (
        <li>
          <a 
            href={`/categories/${category}`} 
            class="group flex items-center justify-between px-3.5 py-3 rounded-2xl text-sm text-zinc-600 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-900/40 border border-transparent hover:border-zinc-200/30 dark:hover:border-zinc-800/50 hover:shadow-[inset_0_1px_2px_rgba(0,0,0,0.01)] transition-all duration-300 ease-out"
          >

            <span class="flex items-center gap-2">
              <span class="text-zinc-300 dark:text-zinc-600 group-hover:text-zinc-400 group-hover:-translate-x-0.5 group-hover:opacity-40 transition-all duration-300 ease-out font-medium">
                #
              </span>
              <span class="font-medium text-zinc-600 dark:text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-white transition-colors duration-300">
                {category}
              </span>
            </span>
            
            <div class="flex items-center gap-3">
              <span class="text-xs  font-medium text-zinc-400 dark:text-zinc-500 group-hover:text-indigo-500 dark:group-hover:text-yellow-500/80 transition-colors duration-300">
                {count.toString().padStart(2, '0')}
              </span>
              
              <div class="w-0 opacity-0 group-hover:w-3.5 group-hover:opacity-100 transition-all duration-300 ease-out overflow-hidden">
                <Icon name="arrow-right" class="w-3.5 h-3.5 text-indigo-500 dark:text-yellow-500/80" />
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- 一言卡片 -->
  <div transition:persist="left-sidebar-hitokoto" class="p-6 glass-card glass-card-dark">
    
    <div class="flex gap-4 items-start min-h-[100px]">
      
      <div class="text-4xl font-serif text-text-light/20 dark:text-text-dark/25 leading-none select-none mt-1">“</div>
      
      <div class="flex-1 flex flex-col justify-between min-h-[100px]">
        
        <p class="hitokoto-text text-sm md:text-base text-text-light/90 dark:text-text-dark/90 font-medium leading-relaxed tracking-wide w-full">
          加载中...
        </p>
        
        <div class="flex items-center justify-between border-t border-black/6 dark:border-white/6 pt-3 mt-4">
          <span class="text-[10px] font-bold tracking-widest text-dim uppercase ">HITO</span>
          <p class="hitokoto-from text-xs text-text-light/60 dark:text-text-dark/60 font-light tracking-wide min-h-[1em]"></p>
        </div>
        
      </div>
    </div>

  </div>

  <!-- 最近在看卡片 -->
  <div transition:persist="left-sidebar-watching" class="p-6 glass-card glass-card-dark">
    
    <!-- 顶部标题栏 - 加号方块解构 -->
    <div class="flex items-center justify-between mb-4">
      <p class="text-base font-semibold text-text-light dark:text-text-dark uppercase tracking-wider">最近在看</p>
      <a href="/watching" class="group/more flex items-center text-[11px] font-bold text-text-light/40 dark:text-text-dark/45 uppercase tracking-widest transition-colors duration-300 hover:text-text-light dark:hover:text-text-dark">
        <!-- 隐藏的“+”号：悬停时从 0 放大、显现，并推出文字 -->
        <span class="inline-block transform scale-0 opacity-0 max-w-0 transition-all duration-300 ease-out group-hover/more:scale-100 group-hover/more:opacity-100 group-hover/more:max-w-[14px] group-hover/more:text-primary-light dark:group-hover/more:text-primary-dark  text-xs">+</span>
        <span class="transition-transform duration-300 group-hover/more:translate-x-0.5">More</span>
      </a>
    </div>

    <!-- 列表区域 -->
    <div class="space-y-4">
      {watchingList.slice(0, 3).map((item, idx) => (
        <div class="flex gap-3 group/item items-center">
          
          <!-- 左侧封面 -->
          <a href={`/tonight?idx=${idx}`} class="w-16 h-20 shrink-0 rounded-xl overflow-hidden bg-hover-light dark:bg-hover-dark cursor-pointer block relative shadow-sm">
            <img
              src={item.cover.replace(/\/view\/photo\/[lms]\//, '/view/photo/thumb/')}
              alt={item.title}
              class="w-full h-full object-cover group-hover/item:scale-105 transition-transform duration-500 ease-out"
              loading="lazy"
            />
          </a>

          <!-- 右侧信息区 -->
          <div class="flex-1 min-w-0 transform-gpu" style={{ backfaceVisibility: 'hidden' }}>
            
            <!-- 标题 + 评分 -->
            <div class="flex items-center justify-between mb-0.5">
              <h4 class="text-sm font-bold text-text-light dark:text-text-dark line-clamp-1 group-hover/item:text-primary-light dark:group-hover/item:text-primary-dark transition-colors duration-300">
                <a href={`/tonight?idx=${idx}`}>{item.title}</a>
              </h4>
              {item.ratings && item.ratings.length > 0 && (
                <div class="flex items-center gap-0.5 shrink-0 ml-2">
                  <img src={ratingIcons[item.ratings[0].source]} alt="评分" class="w-3.5 h-3.5" />
                  <span class="text-xs font-black text-yellow-600 dark:text-yellow-400 ">{item.ratings[0].score.toFixed(1)}</span>
                </div>
              )}
            </div>

            <!-- 元数据标签 -->
            <div class="flex items-center text-[10px] font-bold text-text-light/40 dark:text-text-dark/45 uppercase tracking-widest mb-1 select-none">
              <span>{item.type}</span>
              <span class="mx-1 opacity-60">/</span>
              {item.country && (
                <>
                  <span>{item.country}</span>
                  <span class="mx-1 opacity-60">/</span>
                </>
              )}
              <span class="">{item.year}</span>
            </div>

            <a 
              href={`/tonight?idx=${idx}`}
              class="text-xs text-text-light/60 dark:text-text-dark/60 text-left break-all leading-normal tracking-wide transition-colors duration-300 group-hover/item:text-text-light/90 dark:group-hover/item:text-text-dark/90 p-0! m-0! [display:-webkit-box] [-webkit-line-clamp:2] [-webkit-box-orient:vertical] overflow-hidden" 
            >
              {item.comment}
            </a>
            
          </div>
        </div>
      ))}
    </div>

  </div>
</aside>

<style is:global>
  #hidden-aplayer {
    position: absolute !important;
    visibility: hidden !important;
    pointer-events: none !important;
  }

  @keyframes wave-stretch {
    0%, 100% { 
      transform: scaleY(var(--min-scale, 0.5)); 
    }
    50% { 
      transform: scaleY(var(--max-scale, 0.85)); 
    }
  }

  .bar-anim {
    transform-origin: center;
    animation: wave-stretch 1.2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    animation-delay: var(--delay);
    will-change: transform;
  }

  .vinyl-record {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    position: relative;
    background: #0d0d11;
    overflow: hidden;
    --vinyl-shadow: 0 12px 24px -4px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(0, 0, 0, 0.9);
    --vinyl-rim: inset 0 0 0 1.5px rgba(255, 255, 255, 0.08);
    --vinyl-gloss-opacity: 0.15;
    box-shadow: var(--vinyl-shadow), var(--vinyl-rim);
  }

  .dark .vinyl-record {
    --vinyl-shadow: 0 16px 32px -8px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(0, 0, 0, 0.7);
    --vinyl-rim: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
    --vinyl-gloss-opacity: 0.1;
  }

  .vinyl-record::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: 
      conic-gradient(
        from 170deg at 50% 50%,
        transparent 0deg,
        rgba(255, 255, 255, var(--vinyl-gloss-opacity)) 35deg, 
        transparent 70deg,
        transparent 180deg,
        rgba(255, 255, 255, var(--vinyl-gloss-opacity)) 215deg,
        transparent 250deg,
        transparent 360deg
      ),
      repeating-radial-gradient(
        circle at center,
        #0d0d11 0px,
        #181820 1px,
        #0d0d11 2px
      );
    pointer-events: none;
    z-index: 1;
  }

  .vinyl-record::after {
    content: '';
    position: absolute;
    inset: 12px; 
    border-radius: 50%;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.03);
    box-shadow: inset 0 0 12px rgba(0, 0, 0, 0.85);
    z-index: 2;
  }

  @keyframes cover-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .vinyl-record.playing {
    animation: cover-spin 12s linear infinite;
  }

  .vinyl-record.paused {
    animation-play-state: paused;
  }
  
  /* 容器相对定位 */
  .avatar-container {
    position: relative;
  }

  /* 默认状态：所有 Emoji 隐藏、缩小、带有模糊和旋转 */
  .static-emoji {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 135px;
    height: 135px;
    min-width: 135px;
    min-height: 135px;
    object-fit: contain;
    z-index: 9999;
    user-select: none;
    pointer-events: none; /* 默认不挡鼠标 */
    display: none;        /* 非激活时完全不参与布局 */
    opacity: 0;
    transform: translate(-50%, -50%) perspective(1000px) rotateY(-25deg) scale(0.7);
    filter: blur(4px) brightness(1.1);
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* 激活状态（对应原本的节拍1-4） */
  .static-emoji[data-state="active"] {
    display: block;
    opacity: 1;
    pointer-events: auto;
    cursor: pointer;
    transform: translate(-50%, -50%) perspective(1000px) rotateY(0deg) rotateZ(0deg) scale(1);
    filter: blur(0px) brightness(1);
  }

  /* 刚登场弹起的一瞬间（可以加个微调效果，这里直接交给 active 的 transition 即可） */
  .static-emoji[data-state="enter"] {
    display: block;
    opacity: 1;
    pointer-events: auto;
    cursor: pointer;
    transform: translate(-50%, -50%) perspective(1000px) rotateY(0deg) rotateZ(5deg) scale(1.2);
    filter: blur(0px) brightness(1);
  }

  /* 退场状态（对应节拍5） */
  .static-emoji[data-state="exit"] {
    display: block;
    opacity: 0;
    transform: translate(-50%, -50%) perspective(1000px) rotateY(25deg) rotateZ(5deg) scale(0.9);
    filter: blur(4px) brightness(1.1);
  }
</style>

<!-- Emoji 头像切换 -->
<script>
  let avatarTimeout: number | undefined;
  let animTimers: number[] = []; // 用于收集当前周期所有定时器，方便统一安全清理
  let isAvatarAnimating = false;

  function initEmojiEffects() {
    cleanupEmoji(); // 启动时先彻底清空残留

    const emojiTexts: Record<string, string> = {
      'cool': '传奇主唱井芹仁菜',
      'cat': '磁场转动九十九万匹！',
      'yummy': '全款拿下疯狂星期四',
      'cry': '咕咕嘎嘎！咕嘎？',
      'nerd': '感觉不如……原神',
      'laugh': '知识学爆'
    };

    const emojiKeys = Object.keys(emojiTexts);
    const avatarImage = document.querySelector('.avatar-image') as HTMLImageElement;
    const greetingText = document.querySelector('.greeting-text') as HTMLElement;
    const greetingContainer = greetingText?.parentElement as HTMLElement;

    // 辅助工具：向调度桶里注入延时任务
    const schedule = (fn: () => void, delay: number) => {
      const timer = window.setTimeout(fn, delay);
      animTimers.push(timer);
    };

    function triggerAvatarChange() {
      if (!avatarImage || isAvatarAnimating) return;
      isAvatarAnimating = true;

      // 每次随机捞 3 个不同的 Emoji 出来跑马灯
      const shuffled = [...emojiKeys].sort(() => Math.random() - 0.5).slice(0, 3);

      // 1. 原头像/文字 退场
      avatarImage.style.transform = 'perspective(1000px) rotateY(25deg) rotateZ(5deg) scale(0.9)';
      avatarImage.style.opacity = '0';
      avatarImage.style.transition = 'all 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
      avatarImage.style.filter = 'blur(4px) brightness(1.1)';

      if (greetingText && greetingContainer) {
        [greetingText, greetingContainer].forEach(el => {
          el.style.transform = 'scale(0.9) translateZ(0)';
          el.style.opacity = '0';
          el.style.transition = 'all 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
          el.style.filter = 'blur(2px) brightness(1.1)';
        });
      }

      schedule(() => { avatarImage.style.visibility = 'hidden'; }, 450);

      // 2. 依次编排 3 个静态 Emoji 的高保真舞台秀
      let timelineCursor = 500; // 时间轴游标，毫秒

      shuffled.forEach((fileKey) => {
        const emojiEl = document.querySelector(`.static-emoji[data-file="${fileKey}"]`) as HTMLElement;
        if (!emojiEl) return;

        // 【核心防御】：进场前，确保它的状态是干净的隐藏态
        schedule(() => {
          emojiEl.removeAttribute('data-state');
          emojiEl.style.display = 'block'; 
        }, timelineCursor);

        timelineCursor += 50;

        // 节拍 1：弹起登场
        schedule(() => {
          emojiEl.setAttribute('data-state', 'enter');
          if (greetingText && greetingContainer) {
            greetingText.textContent = emojiTexts[fileKey];
            [greetingText, greetingContainer].forEach(el => {
              el.style.transform = 'scale(1.2) translateZ(0)';
              el.style.opacity = '1';
              el.style.filter = 'blur(0px) brightness(1)';
              el.style.transition = 'all 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
            });
          }
        }, timelineCursor);

        timelineCursor += 300;

        // 节拍 2 & 3：回弹至完美归位
        schedule(() => {
          emojiEl.setAttribute('data-state', 'active');
          if (greetingText && greetingContainer) {
            greetingText.style.transform = 'scale(1) translateZ(0)';
            greetingContainer.style.transform = 'scale(1) translateZ(0)';
          }
        }, timelineCursor);

        // 节拍 4：展示停留 (3秒)
        timelineCursor += 3000;

        // 节拍 5：退场倾斜淡出
        schedule(() => {
          emojiEl.setAttribute('data-state', 'exit');
          if (greetingText && greetingContainer) {
            [greetingText, greetingContainer].forEach(el => {
              el.style.transform = 'scale(0.9) translateZ(0)';
              el.style.opacity = '0';
              el.style.filter = 'blur(2px) brightness(1.1)';
            });
          }
        }, timelineCursor);

        timelineCursor += 550;

        // 最终步：谢幕关灯，恢复初始隐形态，让出舞台
        schedule(() => {
          emojiEl.removeAttribute('data-state');
          emojiEl.style.display = 'none';
        }, timelineCursor);

        timelineCursor += 400; // 下一个 Emoji 登场前的空隙延迟
      });

      // 3. 原头像王者回归
      schedule(() => {
        avatarImage.style.visibility = 'visible';
        avatarImage.style.transform = 'perspective(1000px) rotateY(-25deg) rotateZ(-5deg) scale(0.9)';
        avatarImage.style.opacity = '0';
        avatarImage.style.filter = 'blur(4px) brightness(1.1)';
        
        if (greetingText && greetingContainer) {
          greetingText.textContent = '醉后不知天在水';
          [greetingText, greetingContainer].forEach(el => {
            el.style.transform = 'scale(0.9) translateZ(0)';
            el.style.opacity = '0';
            el.style.filter = 'blur(2px) brightness(1.1)';
          });
        }
      }, timelineCursor);

      timelineCursor += 100;

      schedule(() => {
        avatarImage.style.transform = 'perspective(1000px) rotateY(0deg) rotateZ(0deg) scale(1)';
        avatarImage.style.opacity = '1';
        avatarImage.style.filter = 'blur(0px) brightness(1)';
        avatarImage.style.transition = 'all 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
        
        if (greetingText && greetingContainer) {
          [greetingText, greetingContainer].forEach(el => {
            el.style.transform = 'scale(1)';
            el.style.opacity = '1';
            el.style.filter = 'blur(0px) brightness(1)';
            el.style.transition = 'all 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
          });
        }
      }, timelineCursor);

      timelineCursor += 600;

      // 宣告本轮大功告成，拉响下一个 15s 之后的警报
      schedule(() => {
        isAvatarAnimating = false;
        avatarTimeout = window.setTimeout(triggerAvatarChange, 5000);
      }, timelineCursor);
    }

    // 进站 3 秒后执行首次秀
    avatarTimeout = window.setTimeout(triggerAvatarChange, 3000);
  }

  function cleanupEmoji() {
    if (avatarTimeout) clearTimeout(avatarTimeout);
    animTimers.forEach(t => clearTimeout(t));
    animTimers = [];
    isAvatarAnimating = false;

    // 强制复位所有静态图片，确保没有遗留
    document.querySelectorAll('.static-emoji').forEach(el => {
      el.removeAttribute('data-state');
      (el as HTMLElement).style.display = 'none';
    });
  }

  // 挂载 Astro 标准生命周期
  initEmojiEffects();
  document.addEventListener('astro:page-load', initEmojiEffects);
  document.addEventListener('astro:before-preparation', cleanupEmoji);
</script>

<!-- Matrix与鼠标跟随 -->
<script>
  let matrixInterval: number | undefined;
  let animationFrameId: number | undefined;
  let matrixListenersBound = false;

  function initSecondaryEffects() {
    const matrixCard = document.querySelector('.matrix-card');
    const matrixTexts = matrixCard?.querySelectorAll('.matrix-text') || [];
    const matrixChars = '0123456789ABCDEFG';
    let isAnimating = false;
    let changeCount = 0; 

    if (matrixInterval) clearInterval(matrixInterval);
    if (animationFrameId) cancelAnimationFrame(animationFrameId);

    // --- 鼠标跟随效果独立运行 ---
    const mouseWrapper = document.querySelector('.avatar-mouse-wrapper') as HTMLElement;
    let mouseX = 0, mouseY = 0;
    let currentX = 0, currentY = 0;
    const lerpFactor = 0.04; 
    const maxMoveDistance = 6; 
    let isHovering = false;

    if (mouseWrapper) {
      mouseWrapper.addEventListener('mouseenter', () => { isHovering = true; });
      mouseWrapper.addEventListener('mousemove', (e: Event) => {
        if (!isHovering) return;
        const mouseEvent = e as MouseEvent;
        const rect = mouseWrapper.getBoundingClientRect();
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height / 2;
        const normalizedX = (mouseEvent.clientX - centerX) / (rect.width / 2);
        const normalizedY = (mouseEvent.clientY - centerY) / (rect.height / 2);
        mouseX = Math.max(-1, Math.min(1, normalizedX)) * maxMoveDistance;
        mouseY = Math.max(-1, Math.min(1, normalizedY)) * maxMoveDistance;
      });
      mouseWrapper.addEventListener('mouseleave', () => {
        isHovering = false;
        mouseX = 0; mouseY = 0;
      });

      function animateMouseFollow() {
        currentX += (mouseX - currentX) * lerpFactor;
        currentY += (mouseY - currentY) * lerpFactor;
        mouseWrapper.style.transform = `translate(${currentX}px, ${currentY}px)`;
        animationFrameId = requestAnimationFrame(animateMouseFollow);
      }
      animateMouseFollow();
    }

    // --- 文字矩阵特效独立运行 ---
    const matrixTextPairs = [
      { name: '波罗歌', desc: '万维网中潮汛来' },
      { name: '波罗阁', desc: '今日方知我是我' }
    ];
    let currentTextPairIndex = 0;

    function triggerMatrixEffect() {
      if (isAnimating || matrixTexts.length === 0) return;
      isAnimating = true;
      changeCount++;
      
      currentTextPairIndex = (currentTextPairIndex + 1) % matrixTextPairs.length;
      const newTextPair = matrixTextPairs[currentTextPairIndex];
      
      matrixTexts.forEach((element, index) => {
        const targetText = index === 0 ? newTextPair.name : newTextPair.desc;
        const chars = targetText.split('');
        const isEvenIndex = index % 2 === 0;
        const isEvenChange = changeCount % 2 === 0;
        const shouldReverse = isEvenChange ? isEvenIndex : !isEvenIndex;
        let revealIndex = shouldReverse ? chars.length : 0;
        
        element.textContent = chars.map(() => matrixChars[Math.floor(Math.random() * matrixChars.length)]).join('');
        
        const scrambleInterval = setInterval(() => {
          element.textContent = element.textContent.split('').map((_, i) => {
            if (shouldReverse) {
              return i >= revealIndex ? targetText[i] : matrixChars[Math.floor(Math.random() * matrixChars.length)];
            } else {
              return i < revealIndex ? targetText[i] : matrixChars[Math.floor(Math.random() * matrixChars.length)];
            }
          }).join('');
          
          if (shouldReverse) {
            revealIndex--;
            if (revealIndex < 0) {
              clearInterval(scrambleInterval);
              element.textContent = targetText;
              (element as HTMLElement).dataset.text = targetText;
              if (index === matrixTexts.length - 1) isAnimating = false;
            }
          } else {
            revealIndex++;
            if (revealIndex > chars.length) {
              clearInterval(scrambleInterval);
              element.textContent = targetText;
              (element as HTMLElement).dataset.text = targetText;
              if (index === matrixTexts.length - 1) isAnimating = false;
            }
          }
        }, 50);
      });
    }
    
    // 避免路由切换后重复绑定事件监听器
    if (!matrixListenersBound && matrixCard) {
      matrixCard.addEventListener('mouseenter', triggerMatrixEffect);
      const textContainer = matrixCard.querySelector('.text-container');
      if (textContainer) textContainer.addEventListener('mouseenter', triggerMatrixEffect);
      matrixListenersBound = true;
    }

    matrixInterval = setInterval(triggerMatrixEffect, 10000) as unknown as number;
  }

  function cleanupSecondary() {
    if (matrixInterval) clearInterval(matrixInterval);
    if (animationFrameId) cancelAnimationFrame(animationFrameId);
    matrixListenersBound = false;
  }

  initSecondaryEffects();
  document.addEventListener('astro:page-load', initSecondaryEffects);
  document.addEventListener('astro:before-preparation', cleanupSecondary);
</script>  

<script>
  interface HitokotoData {
    hitokoto: string;
    from?: string;
  }

  interface HitokotoCache {
    data: HitokotoData;
    timestamp: number;
  }

  const HITOKOTO_CACHE_KEY = 'hitokoto_cache';
  const HITOKOTO_CACHE_DURATION = 3600000; // 1小时缓存

  function getCachedHitokoto(): HitokotoData | null {
    try {
      const cached = localStorage.getItem(HITOKOTO_CACHE_KEY);
      if (cached) {
        const { data, timestamp }: HitokotoCache = JSON.parse(cached);
        if (Date.now() - timestamp < HITOKOTO_CACHE_DURATION) {
          return data;
        }
      }
    } catch (error) {
      console.error('Failed to get cached hitokoto:', error);
    }
    return null;
  }

  function setCachedHitokoto(data: HitokotoData) {
    try {
      localStorage.setItem(HITOKOTO_CACHE_KEY, JSON.stringify({
        data,
        timestamp: Date.now()
      }));
    } catch (error) {
      console.error('Failed to cache hitokoto:', error);
    }
  }

  function updateHitokotoUI(data: HitokotoData) {
    const textEls = document.querySelectorAll('.hitokoto-text');
    const fromEls = document.querySelectorAll('.hitokoto-from');

    textEls.forEach(el => el.textContent = data.hitokoto);
    fromEls.forEach(el => el.textContent = data.from ? `—— ${data.from}` : '');
  }

  async function fetchHitokoto() {
    try {
      const response = await fetch('https://v1.hitokoto.cn');
      const data: HitokotoData = await response.json();
      setCachedHitokoto(data);
      updateHitokotoUI(data);
    } catch (error) {
      console.error('Failed to fetch hitokoto:', error);
    }
  }

  function initHitokoto() {
    const cached = getCachedHitokoto();
    if (cached) {
      updateHitokotoUI(cached);
      // 缓存有效期内不重复请求
      return;
    }

    const defaultText = '醉后不知天在水，满船清梦压星河。';
    document.querySelectorAll('.hitokoto-text').forEach(el => {
      if (!el.textContent || el.textContent === '加载中...') {
        el.textContent = defaultText;
      }
    });

    requestIdleCallback(() => {
      fetchHitokoto();
    }, { timeout: 2000 });
  }

  function initPlaylistCover() {
    const playlistCover = document.getElementById('playlist-cover') as HTMLImageElement | null;
    if (playlistCover) {
      playlistCover.addEventListener('error', function(this: HTMLImageElement) {
        this.src = 'https://picsum.photos/200/200?blur';
      });
    }
  }

  document.addEventListener('astro:page-load', () => {
    initHitokoto();
    initPlaylistCover();
  });

  // 避免路由切换后累积多个定时器
  if (!(window as any).__hitokotoInterval) {
    (window as any).__hitokotoInterval = setInterval(fetchHitokoto, 300000);
  }
</script>

<script>
  // 音乐卡片播放控制
  interface SongData {
    name?: string;
    title?: string;
    artist?: string;
    author?: string;
    url: string;
    pic?: string;
    cover?: string;
    lrc?: string;
    playlist_name?: string;
  }

  interface MusicPlayerState {
    ap: APlayerInstance | null;
    songsData: SongData[];
    isInitialized: boolean;
    updateTimer: ReturnType<typeof setInterval> | null;
    previousIndex?: number;
  }

  // APlayer 实例的类型声明（仅包含使用到的属性和方法）
  interface APlayerInstance {
    audio: HTMLAudioElement & { duration: number };
    list: {
      audios: { name: string; artist: string; cover: string; url: string; lrc: string }[];
      index: number;
      switch(index: number): void;
    };
    play(): void;
    pause(): void;
    seek(time: number): void;
    on(event: string, callback: () => void): void;
  }

  declare class APlayer {
    constructor(options: {
      container: HTMLElement | null;
      autoplay: boolean;
      theme: string;
      loop: string;
      preload: string;
      volume: number;
      mutex: boolean;
      audio: { name: string; artist: string; url: string; cover: string; lrc: string }[];
    });
    audio: HTMLAudioElement & { duration: number };
    list: APlayerInstance['list'];
    play(): void;
    pause(): void;
    seek(time: number): void;
    on(event: string, callback: () => void): void;
  }

  // 扩展 Window 接口
  declare global {
    interface Window {
      musicPlayerState: MusicPlayerState;
      musicPlayerUpdateUI: (() => void) | undefined;
      musicPlayerUpdateProgress: (() => void) | undefined;
      togglePlay: (() => void) | undefined;
      playPrev: (() => void) | undefined;
      playNext: (() => void) | undefined;
    }
  }

  // 全局状态管理
  window.musicPlayerState = window.musicPlayerState || {
    ap: null,
    songsData: [],
    isInitialized: false,
    updateTimer: null
  };

  let ap = window.musicPlayerState.ap;
  let songsData = window.musicPlayerState.songsData;
  let updateTimer = window.musicPlayerState.updateTimer;

  // 加载 APlayer
  function loadAPlayer(): Promise<void> {
    return new Promise((resolve, reject) => {
      if (typeof APlayer !== 'undefined') {
        resolve();
        return;
      }
      const script = document.createElement('script');
      script.src = '/libs/aplayer/APlayer.min.js';
      script.onload = () => resolve();
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }

  function initProgressBarClick() {
    const progressBar = document.getElementById('progress-bar');
    const progressContainer = progressBar?.parentElement;

    if (progressContainer && !progressContainer.dataset.clickBound) {
      progressContainer.addEventListener('click', function(e: MouseEvent) {
        const currentAp = window.musicPlayerState.ap;
        if (!currentAp || !currentAp.audio.duration) return;

        const rect = progressContainer.getBoundingClientRect();
        const clickX = e.clientX - rect.left;
        const containerWidth = rect.width;

        let percentage = clickX / containerWidth;
        percentage = Math.max(0, Math.min(1, percentage));

        const targetTime = percentage * currentAp.audio.duration;
        currentAp.seek(targetTime);
      });

      progressContainer.dataset.clickBound = "true";
    }
  }

  // 初始化播放器
  async function initPlayer() {
    if (window.musicPlayerState.isInitialized && ap) {
      initProgressBarClick();
      return;
    }

    try {
      await loadAPlayer();

      const apiEndpoints = [
        'https://api.injahow.cn/meting/?type=playlist&id=2732533345&server=netease&limit=50',
        'https://meting.jinghuashang.cn/?type=playlist&id=2732533345&server=netease&limit=50',
        'https://metingapi.mo-app.cn/?type=playlist&id=2732533345&server=netease&limit=50'
      ];

      let data: SongData[] | null = null;

      for (const endpoint of apiEndpoints) {
        try {
          const response = await fetch(endpoint);
          const responseData: SongData[] = await response.json();

          if (Array.isArray(responseData) && responseData.length > 0) {
            data = responseData;
            console.log(`Successfully fetched playlist from: ${endpoint}`);
            break;
          } else {
            console.warn(`API returned invalid data from: ${endpoint}`, responseData);
          }
        } catch (error) {
          console.warn(`Failed to fetch from ${endpoint}:`, error);
        }
      }

      if (!data || data.length === 0) {
        console.error('Failed to fetch playlist from all endpoints');
        return;
      }

      songsData = data;

      const countEl = document.getElementById('playlist-count');
      if (countEl) {
        countEl.textContent = `${data.length} 首歌曲`;
      }

      if (data[0] && data[0].playlist_name) {
        const nameEl = document.getElementById('playlist-name');
        if (nameEl) nameEl.textContent = data[0].playlist_name;
      }

      if (data[0] && data[0].pic) {
        const coverEl = document.getElementById('playlist-cover') as HTMLImageElement | null;
        if (coverEl) coverEl.src = data[0].pic;
      }

      const audioList = data.map(item => ({
        name: item.name || item.title || '未知歌曲',
        artist: item.artist || item.author || '未知艺术家',
        url: item.url,
        cover: item.pic || item.cover || '',
        lrc: item.lrc || ''
      }));

      ap = new APlayer({
        container: document.getElementById('hidden-aplayer'),
        autoplay: false,
        theme: '#3b82f6',
        loop: 'all',
        preload: 'auto',
        volume: 0.7,
        mutex: true,
        audio: audioList
      });

      window.musicPlayerState.ap = ap;
      window.musicPlayerState.songsData = songsData;
      window.musicPlayerState.isInitialized = true;

      ap.on('play', () => window.musicPlayerUpdateUI?.());
      ap.on('pause', () => window.musicPlayerUpdateUI?.());
      ap.on('timeupdate', () => window.musicPlayerUpdateProgress?.());

      initProgressBarClick();
      startPeriodicUpdate();
    } catch (error) {
      console.error('Failed to initialize player:', error);
      const countEl = document.getElementById('playlist-count');
      if (countEl) {
        countEl.textContent = '加载失败';
      }
    }
  }

  // 更新播放状态 UI（全局函数）
  window.musicPlayerUpdateUI = function() {
    const currentAp = window.musicPlayerState.ap;
    if (!currentAp) return;

    const isPlaying = !currentAp.audio.paused;
    const currentSong = currentAp.list.audios[currentAp.list.index];
    const currentIndex = currentAp.list.index;

    const controlPlayIcon = document.getElementById('control-play-icon');
    const controlPauseIcon = document.getElementById('control-pause-icon');
    const indicator = document.getElementById('playing-indicator');
    const currentSongEl = document.getElementById('current-song');
    const coverImg = document.getElementById('playlist-cover') as HTMLImageElement | null;
    const vinylRecord = document.querySelector('.vinyl-record');

    const previousIndex = window.musicPlayerState.previousIndex ?? -1;
    const hasChangedSong = previousIndex !== currentIndex;

    if (isPlaying) {
      vinylRecord?.classList.add('playing');
      vinylRecord?.classList.remove('paused');
    } else {
      vinylRecord?.classList.add('paused');
    }

    if (currentSong) {
      if (currentSongEl) {
        currentSongEl.textContent = `${currentSong.name} - ${currentSong.artist}`;
      }

      if (hasChangedSong && coverImg && currentSong.cover && coverImg.src !== currentSong.cover) {
        coverImg.style.opacity = '0';
        setTimeout(() => {
          coverImg.src = currentSong.cover;
          coverImg.style.opacity = '1';
        }, 250);
      } else if (!hasChangedSong && coverImg && currentSong.cover && coverImg.src !== currentSong.cover) {
        coverImg.src = currentSong.cover;
      }
    }

    window.musicPlayerState.previousIndex = currentIndex;

    if (isPlaying) {
      controlPlayIcon?.classList.add('hidden');
      controlPauseIcon?.classList.remove('hidden');
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          indicator?.classList.remove('opacity-0');
        });
      });
    } else {
      controlPlayIcon?.classList.remove('hidden');
      controlPauseIcon?.classList.add('hidden');
      indicator?.classList.add('opacity-0');
    }
  };

  // 更新进度条（全局函数）
  window.musicPlayerUpdateProgress = function() {
    const currentAp = window.musicPlayerState.ap;
    if (!currentAp) return;

    const progressBar = document.getElementById('progress-bar');
    const currentTimeEl = document.getElementById('current-time');
    const totalTimeEl = document.getElementById('total-time');

    if (progressBar) {
      const percent = (currentAp.audio.currentTime / currentAp.audio.duration) * 100 || 0;
      progressBar.style.width = `${percent}%`;
    }

    if (currentTimeEl) {
      currentTimeEl.textContent = formatTime(currentAp.audio.currentTime);
    }

    if (totalTimeEl) {
      totalTimeEl.textContent = formatTime(currentAp.audio.duration || 0);
    }
  };

  function formatTime(seconds: number): string {
    const mins = Math.floor(seconds / 60);
    const secs = Math.floor(seconds % 60);
    return `${mins}:${secs.toString().padStart(2, '0')}`;
  }

  function startPeriodicUpdate() {
    if (updateTimer) clearInterval(updateTimer);
    updateTimer = setInterval(() => {
      window.musicPlayerUpdateUI?.();
      window.musicPlayerUpdateProgress?.();
    }, 100);
    window.musicPlayerState.updateTimer = updateTimer;
  }

  // 播放/暂停
  window.togglePlay = function() {
    const currentAp = window.musicPlayerState.ap;
    if (!currentAp || !currentAp.list.audios.length) return;
    if (currentAp.audio.paused) {
      currentAp.play();
    } else {
      currentAp.pause();
    }
  };

  // 上一首
  window.playPrev = function() {
    const currentAp = window.musicPlayerState.ap;
    if (!currentAp || !currentAp.list.audios.length) return;
    currentAp.list.switch(currentAp.list.index - 1 < 0 ? currentAp.list.audios.length - 1 : currentAp.list.index - 1);
    currentAp.play();
  };

  // 下一首
  window.playNext = function() {
    const currentAp = window.musicPlayerState.ap;
    if (!currentAp || !currentAp.list.audios.length) return;
    currentAp.list.switch(currentAp.list.index + 1 >= currentAp.list.audios.length ? 0 : currentAp.list.index + 1);
    currentAp.play();
  };

  // 初始化
  function initMusicPlayer() {
    if (!window.musicPlayerState.isInitialized) {
      initPlayer();
    } else {
      startPeriodicUpdate();
      window.musicPlayerUpdateUI?.();
      window.musicPlayerUpdateProgress?.();
      initProgressBarClick();
    }
  }

  // 处理 ViewTransitions - 页面切换后恢复 UI
  document.addEventListener('astro:after-swap', () => {
    startPeriodicUpdate();
    window.musicPlayerUpdateUI?.();
    window.musicPlayerUpdateProgress?.();
    initProgressBarClick();

    const currentSongsData = window.musicPlayerState.songsData;
    if (currentSongsData && currentSongsData.length > 0) {
      const countEl = document.getElementById('playlist-count');
      if (countEl) {
        countEl.textContent = `${currentSongsData.length} 首歌曲`;
      }

      if (currentSongsData[0] && currentSongsData[0].playlist_name) {
        const nameEl = document.getElementById('playlist-name');
        if (nameEl) nameEl.textContent = currentSongsData[0].playlist_name;
      }

      if (currentSongsData[0] && currentSongsData[0].pic) {
        const coverEl = document.getElementById('playlist-cover') as HTMLImageElement | null;
        if (coverEl) coverEl.src = currentSongsData[0].pic;
      }
    }

    const currentAp = window.musicPlayerState.ap;
    if (currentAp && currentAp.list.audios.length > 0) {
      const currentSong = currentAp.list.audios[currentAp.list.index];
      const coverEl = document.getElementById('playlist-cover') as HTMLImageElement | null;
      if (coverEl && currentSong?.cover) {
        coverEl.src = currentSong.cover;
      }
    }
  });

  document.addEventListener('astro:page-load', initMusicPlayer);
</script>
