---
const today = new Date();
import Icon from './Icon.astro';
---

<footer transition:persist="site-footer" class="border-t border-border-light dark:border-border-dark">
    <div class="section-container py-10">
        
        <div class="flex flex-col items-center md:items-start space-y-4 mb-6">
            <div class="flex items-center space-x-2">
                <span class="text-sm text-gray-500 dark:text-gray-400">Powered by</span>
                <div class="bg-black/5 dark:bg-white/10 rounded-full px-3 py-1.5 flex items-center space-x-3">
                    <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="group relative text-gray-500 dark:text-gray-400 [@media(hover:hover)]:hover:text-gray-800 dark:[@media(hover:hover)]:hover:text-white transition-colors" aria-label="GitHub - 代码托管平台">
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl tooltip [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 origin-bottom">GitHub - 代码托管平台</div>
                        <Icon name="github" class="w-4 h-4" />
                    </a>
                    <a href="https://vercel.com" target="_blank" rel="noopener noreferrer" class="group relative text-gray-500 dark:text-gray-400 [@media(hover:hover)]:hover:text-gray-800 dark:[@media(hover:hover)]:hover:text-white transition-colors" aria-label="Vercel - 边缘分发网络">
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl tooltip [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 origin-bottom">Vercel - 边缘分发网络</div>
                        <Icon name="vercel" class="w-4 h-4" />
                    </a>
                    <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="group relative text-gray-500 dark:text-gray-400 [@media(hover:hover)]:hover:text-gray-800 dark:[@media(hover:hover)]:hover:text-white transition-colors" aria-label="Astro - 静态构建框架">
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl tooltip [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 origin-bottom">Astro - 静态构建框架</div>
                        <Icon name="astro" class="w-4 h-4" />
                    </a>
                    <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="group relative text-gray-500 dark:text-gray-400 [@media(hover:hover)]:hover:text-gray-800 dark:[@media(hover:hover)]:hover:text-white transition-colors" aria-label="Tailwind - 响应式视觉框架">
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl tooltip [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 origin-bottom">Tailwind - 响应式视觉框架</div>
                        <Icon name="tailwind" class="w-4 h-4" />
                    </a>
                </div>
            </div>
            <div class="flex flex-col md:flex-row justify-between items-center w-full gap-2 md:gap-0">
				<span class="text-sm text-gray-500 dark:text-gray-400">
					Design & Build with 🧊 by 
					<a href="https://github.com/LogLInk1K/Multivac" target="_blank" rel="noopener noreferrer" class="group relative [@media(hover:hover)]:hover:text-primary-light dark:[@media(hover:hover)]:hover:text-primary-dark transition-colors underline-offset-4">
						<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl tooltip [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 origin-bottom">
							查看博客开源仓库
						</div>
						LogLInk1K
					</a>
				</span>
				<a href="https://1k.ink" target="_blank" rel="noopener noreferrer" class="group relative inline-flex items-center px-2 py-1 rounded-full [@media(hover:hover)]:hover:bg-primary-light dark:[@media(hover:hover)]:hover:bg-primary-dark transition-colors duration-300 overflow-hidden">
					<span class="flex items-center gap-1.5 transition-all duration-300 [@media(hover:hover)]:group-hover:-translate-y-full [@media(hover:hover)]:group-hover:opacity-0">
						<img src="/img/avatar.webp" alt="波罗歌" class="w-5 h-5 rounded-full" />
						<span class="text-sm text-gray-500 dark:text-gray-400">波罗歌</span>
					</span>
					<span class="absolute inset-0 flex items-center justify-center gap-1.5 px-2 text-sm text-white dark:text-black translate-y-full opacity-0 [@media(hover:hover)]:group-hover:translate-y-0 [@media(hover:hover)]:group-hover:opacity-100 transition-all duration-300 whitespace-nowrap">
						前往主页
					</span>
				</a>
			</div>
        </div>

		<hr class="w-4/5 mx-auto md:w-full border-gray-200 dark:border-gray-800 mb-6" />

        <div class="flex flex-col text-center md:text-left">
            
            <div class="flex flex-col items-center md:items-start gap-2">
				<div class="flex flex-col md:flex-row items-center justify-between w-full gap-2 md:gap-4">
					<p class="text-sm text-gray-500 dark:text-gray-400">
						Copyright &copy; 2021 - {today.getFullYear()}
					</p>
					<a href="https://creativecommons.org/licenses/by-nc-nd/4.0/deed.zh-hans" target="_blank" rel="noopener noreferrer" class="flex items-center space-x-1 group relative" aria-label="知识共享 署名-非商业性使用-禁止演绎 4.0 国际协议">
						<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl tooltip [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 origin-bottom">
							CC BY-NC-ND 4.0 协议
						</div>
						<div class="flex space-x-1 text-text-light dark:text-gray-400 [@media(hover:hover)]:group-hover:text-primary-light dark:[@media(hover:hover)]:group-hover:text-primary-dark transition-colors" aria-hidden="true">
							<Icon name="cc-logo" class="w-5 h-5" />
							<Icon name="cc-by" class="w-5 h-5" />
							<Icon name="cc-nc" class="w-5 h-5" />
							<Icon name="cc-nd" class="w-5 h-5" />
						</div>
					</a>
				</div>
			</div>

            <div class="mt-2 md:mt-0 flex justify-center md:justify-start">
                <a href="https://icp.gov.moe/?keyword=20210325" target="_blank" rel="noopener noreferrer" class="group relative transition-opacity" aria-label="萌ICP备20210325号">
					<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-0.3 whitespace-nowrap px-3 py-2 bg-card-light dark:bg-card-dark tooltip-solid text-text-light dark:text-text-dark text-sm rounded-xl tooltip [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:visible [@media(hover:hover)]:group-hover:scale-100 origin-bottom">
						萌国ICP备案
					</div>
                    <span class="text-[11px] font-medium text-gray-500 dark:text-gray-400">
                        萌ICP备20210325号
                    </span>
                </a>
            </div>

        </div>
    </div>
</footer>
