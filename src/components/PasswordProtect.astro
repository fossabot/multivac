---
import { getSiteConfig } from '../utils/config';

const siteConfig = await getSiteConfig();

interface Props {
    passwordHint?: string;
}

const { passwordHint } = Astro.props;
const defaultHint = siteConfig.passwordHint;
import Icon from './Icon.astro';
---

<style>
    .pwd-input-field {
        -webkit-text-security: disc;
    }
    .pwd-input-field.revealed {
        -webkit-text-security: none;
    }
    .pwd-input-field::-ms-reveal,
    .pwd-input-field::-ms-clear,
    .pwd-input-field::-webkit-credentials-auto-fill-button,
    .pwd-input-field::-webkit-input-password-toggle {
        display: none !important;
    }
</style>

<style is:global>
    .eye-off-icon { display: none; }
    .pwd-toggle-btn.active .eye-on-icon { display: none; }
    .pwd-toggle-btn.active .eye-off-icon { display: block; }
</style>

<div data-password-container class="relative max-w-lg mx-auto mt-12 p-8 sm:p-10 bg-white/70 dark:bg-zinc-900/40 backdrop-blur-xl rounded-3xl border border-zinc-200/50 dark:border-zinc-800/40 shadow-[0_32px_64px_-16px_rgba(0,0,0,0.02)] dark:shadow-[0_32px_64px_-16px_rgba(0,0,0,0.2)] overflow-hidden">
    
    <div class="absolute -top-24 -right-24 w-48 h-48 bg-indigo-500/10 dark:bg-primary-dark/5 blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-emerald-500/5 dark:bg-emerald-500/5 blur-3xl pointer-events-none"></div>

    <div class="text-center flex flex-col items-center gap-6">
        
        <div class="inline-flex items-center gap-3.5">
            <div class="shrink-0 inline-flex items-center justify-center w-10 h-10 rounded-xl bg-zinc-900 dark:bg-zinc-100 text-zinc-100 dark:text-zinc-900 shadow-sm border border-zinc-200/30 dark:border-zinc-700/30">
                <Icon name="lock" class="w-4 h-4" />
            </div>
            <span class="text-2xl font-bold text-zinc-900 dark:text-zinc-50 tracking-tight">
                此文章已加密
            </span>
        </div>
        
        <p class="text-sm text-zinc-400 dark:text-zinc-500 font-medium max-w-xs leading-relaxed">
            这是一篇受密码保护的文章，请输入正确的密码以解析并阅读全部内容。
        </p>

        <form data-password-form action="javascript:void(0)" class="w-full relative group">
            <div class="relative flex items-center bg-zinc-100/80 dark:bg-zinc-950 rounded-xl border border-zinc-200/30 dark:border-zinc-800/80 transition-all duration-300 focus-within:border-zinc-400 dark:focus-within:border-zinc-700 focus-within:ring-4 focus-within:ring-zinc-200/30 dark:focus-within:ring-zinc-900/30 overflow-hidden">
                
                <input
                    type="text"
                    data-password-input
                    placeholder="请输入访问密码..."
                    autocomplete="off"
                    class="pwd-input-field w-full pl-4 pr-24 py-3.5 bg-transparent text-zinc-900 dark:text-zinc-100 placeholder-zinc-400/80 dark:placeholder-zinc-600 outline-none text-sm font-medium tracking-wide text-left"
                />
                
                <div class="absolute right-2 flex items-center gap-1.5">
                    <button type="button" data-toggle-password class="pwd-toggle-btn p-2 text-zinc-400 dark:text-zinc-500 hover:text-zinc-600 dark:hover:text-zinc-400 transition-colors cursor-pointer rounded-lg" aria-label="切换密码可见性">
                        <Icon name="eye" class="w-4 h-4 eye-on-icon" />
                        <Icon name="eye-off" class="w-4 h-4 eye-off-icon" />
                    </button>
                    
                    <button type="submit" class="flex items-center justify-center w-8 h-8 bg-zinc-900 dark:bg-zinc-100 text-zinc-100 dark:text-zinc-900 rounded-lg hover:opacity-90 active:scale-95 transition-all cursor-pointer" aria-label="验证解锁">
                        <Icon name="chevron-right" class="w-4 h-4" />
                    </button>
                </div>
            </div>

            <div data-error-message class="hidden absolute left-1 -bottom-5 text-red-500 dark:text-red-400 text-xs font-semibold tracking-wide"></div>
        </form>
    </div>
    <div class="mt-10 pt-5 border-t border-zinc-200/40 dark:border-zinc-800/30 text-center text-xs text-zinc-400 dark:text-zinc-500">
        {passwordHint || defaultHint}
    </div>

</div>