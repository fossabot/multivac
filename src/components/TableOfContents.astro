<div id="table-of-contents-wrapper" class="hidden xl:block fixed top-1/2 -translate-y-1/2 right-[max(4rem,calc((100vw-1340px)/2-6rem))] w-[180px] opacity-0 transition-opacity duration-500 z-40">
  <div id="toc-list" class="overflow-y-auto group">
    <!-- 目录内容由 JavaScript 生成 -->
  </div>
</div>

<script>
  interface HeadingItem {
    id: string;
    text: string;
    level: string;
  }

  function initTableOfContents() {
    const articleContent = document.querySelector('.prose');
    if (!articleContent) return;

    const tocContainer = document.getElementById('toc-list');
    if (!tocContainer) return;

    const headingElements = articleContent.querySelectorAll('h1, h2');
    if (headingElements.length === 0) return;

    const updateVisibleHeadings = () => {
      const tocLinks = document.querySelectorAll('#toc-list a');
      let currentActiveId: string | null = null;

      const headings = document.querySelectorAll('.prose h1, .prose h2');
      if (headings.length === 0) return;

      const scrollY = window.pageYOffset;
      const viewportMiddleAbsolute = scrollY + window.innerHeight / 2;

      for (let i = 0; i < headings.length; i++) {
        const heading = headings[i];
        const headingTop = heading.getBoundingClientRect().top + scrollY;

        if (headingTop > viewportMiddleAbsolute) {
          if (i > 0) {
            currentActiveId = headings[i - 1].id;
          } else {
            currentActiveId = heading.id;
          }
          break;
        }

        if (i === headings.length - 1) {
          currentActiveId = heading.id;
        }
      }

      let parentH1Id: string | null = null;
      if (currentActiveId) {
        const currentHeading = Array.from(headings).find(h => h.id === currentActiveId);
        if (currentHeading && currentHeading.tagName === 'H2') {
          for (let i = 0; i < headings.length; i++) {
            if (headings[i].id === currentActiveId) {
              for (let j = i - 1; j >= 0; j--) {
                if (headings[j].tagName === 'H1') {
                  parentH1Id = headings[j].id;
                  break;
                }
              }
              break;
            }
          }
        }
      }

      const isHovering = document.querySelector('#toc-list:hover') !== null;

      tocLinks.forEach((link) => {
        const headingId = (link as HTMLElement).dataset.headingId;
        if (!headingId) return;

        const bar = link.previousElementSibling;
        if (!bar || !bar.classList.contains('rounded-full')) return;

        if (isHovering) {
          (link as HTMLElement).style.visibility = 'visible';
          (link as HTMLElement).style.opacity = '1';
          (link as HTMLElement).style.transform = 'translateX(0)';
          link.classList.remove('text-text-light', 'dark:text-text-dark', 'text-text-light/80', 'dark:text-text-dark/80');
          link.classList.add('text-text-light/70', 'dark:text-text-dark/70');
          bar.classList.remove('bg-text-light/50', 'dark:bg-text-dark/50', 'bg-primary-light', 'dark:bg-primary-dark');
          bar.classList.add('bg-text-light/30', 'dark:bg-text-dark/30');
        } else if (headingId === currentActiveId || headingId === parentH1Id) {
          (link as HTMLElement).style.visibility = 'visible';
          (link as HTMLElement).style.opacity = '1';
          (link as HTMLElement).style.transform = 'translateX(0)';
          link.classList.remove('text-text-light', 'dark:text-text-dark', 'text-text-light/70', 'dark:text-text-dark/70');
          link.classList.add('text-text-light/80', 'dark:text-text-dark/80', 'font-bold');
          bar.classList.remove('bg-text-light/30', 'dark:bg-text-dark/30');
          bar.classList.add('bg-text-light/50', 'dark:bg-text-dark/50');
        } else {
          (link as HTMLElement).style.opacity = '0';
          (link as HTMLElement).style.transform = 'translateX(-8px)';
          setTimeout(() => {
            if ((link as HTMLElement).style.opacity === '0') {
              (link as HTMLElement).style.visibility = 'hidden';
            }
          }, 300);
          link.classList.remove('text-text-light/70', 'dark:text-text-dark/70', 'text-text-light/80', 'dark:text-text-dark/80', 'font-bold');
          link.classList.add('text-text-light/70', 'dark:text-text-dark/70');
          bar.classList.remove('bg-text-light/50', 'dark:bg-text-dark/50', 'bg-primary-light', 'dark:bg-primary-dark');
          bar.classList.add('bg-text-light/30', 'dark:bg-text-dark/30');
        }
      });
    };

    const headings: HeadingItem[] = [];

    headingElements.forEach((heading) => {
      const text = heading.textContent || '';
      const id = heading.id || text.toLowerCase().replace(/[^a-z0-9\u4e00-\u9fa5]+/g, '-');
      const level = heading.tagName.toLowerCase();

      if (!heading.id) {
        heading.id = id;
      }

      headings.push({ id, text, level });
    });

    const createListItem = (item: HeadingItem) => {
      const li = document.createElement('li');
      li.style.height = '20px';
      li.style.overflow = 'hidden';

      const wrapper = document.createElement('div');
      wrapper.className = 'flex items-center group/bar';

      const bar = document.createElement('span');
      const barWidth = item.level === 'h2' ? 'w-2.5' : 'w-4';
      bar.className = `${barWidth} h-1 rounded-full bg-text-light/30 dark:bg-text-dark/30 mr-2 shrink-0 transition-colors duration-300 group-hover/bar:bg-primary-light dark:group-hover/bar:bg-primary-dark`;

      const a = document.createElement('a');
      a.href = `#${item.id}`;
      a.textContent = item.text;
      const linkMargin = item.level === 'h2' ? 'ml-1.5' : '';
      a.className = `block text-sm transition-all duration-300 ease-in-out truncate text-text-light/70 dark:text-text-dark/70 font-medium hover:text-primary-light dark:hover:text-primary-dark ${linkMargin}`;
      a.dataset.headingId = item.id;

      wrapper.appendChild(bar);
      wrapper.appendChild(a);
      li.appendChild(wrapper);

      return li;
    };

    const ul = document.createElement('ul');
    ul.className = 'space-y-2';
    headings.forEach((item) => {
      ul.appendChild(createListItem(item));
    });

    tocContainer.innerHTML = '';
    tocContainer.appendChild(ul);

    const tocWrapper = document.getElementById('table-of-contents-wrapper');
    if (tocWrapper) {
      tocWrapper.classList.remove('opacity-0');
    }

    updateVisibleHeadings();

    const tocList = document.getElementById('toc-list');
    if (tocList) {
      tocList.addEventListener('mouseenter', () => {
        updateVisibleHeadings();
      });
      tocList.addEventListener('mouseleave', () => {
        updateVisibleHeadings();
      });
    }

    let scrollTimeout: ReturnType<typeof setTimeout>;
    window.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(updateVisibleHeadings, 100);
    }, { passive: true });

    document.querySelectorAll('#toc-list a').forEach((anchor) => {
      anchor.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = anchor.getAttribute('href')?.substring(1);
        if (!targetId) return;

        const targetElement = document.getElementById(targetId);
        if (targetElement) {
          const offset = 100;
          const targetPosition = targetElement.getBoundingClientRect().top + window.pageYOffset - offset;

          window.scrollTo({
            top: targetPosition,
            behavior: 'smooth',
          });
        }
      });
    });
  }

  document.addEventListener('astro:page-load', () => {
    setTimeout(initTableOfContents, 100);
  });
</script>
