---
import FormattedDate from './FormattedDate.astro';

interface Props {
  title: string;
  url: string;
  author?: string;
  pubDate: Date;
  updatedDate?: Date;
  license?: string;
}

const { title, url, author = '波罗歌', pubDate, updatedDate, license = 'CC BY-NC-ND 4.0' } = Astro.props;

const displayUpdatedDate = updatedDate || pubDate;
import { Icon } from 'astro-icon/components';
---

<div class="article-meta-card bg-gray-50/50 dark:bg-black/50 border border-gray-200/50 dark:border-gray-700/50 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow duration-300 relative overflow-hidden">
  <div class="absolute -right-[58px] top-1/2 -translate-y-1/2 opacity-5 pointer-events-none select-none">
    <Icon name="cc-by" class="w-56 h-56" />
  </div>
  <div class="flex items-center gap-4 mb-4">
    <div class="flex-shrink-0">
      <img 
        src="/img/avatar.webp" 
        alt="作者头像"
        class="w-12 h-12 rounded-full object-cover border-2 border-white/20 dark:border-white/10"
      />
    </div>
    <div class="flex-1 min-w-0">
      <h2 class="text-xl font-bold text-text-light dark:text-text-dark mb-1 truncate leading-tight">{title}</h2>
      <a href={url} class="text-sm text-text-light/70 dark:text-text-dark/70 hover:text-primary-light dark:hover:text-primary-dark truncate block" target="_blank" rel="noopener noreferrer">
        {url}
      </a>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-[auto_1fr] gap-x-12 gap-y-3 text-sm">
    <div class="flex items-center gap-2 text-text-light/70 dark:text-text-dark/70">
      <Icon name="user" class="w-4 h-4 flex-shrink-0" />
      <span class="truncate">作者: {author}</span>
    </div>

    <div class="flex items-center gap-2 text-text-light/70 dark:text-text-dark/70">
      <Icon name="shield" class="w-4 h-4 flex-shrink-0" />
      <span>许可: <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/deed.zh-hans" class="hover:text-primary-light dark:hover:text-primary-dark transition-colors" target="_blank" rel="noopener noreferrer">{license}</a></span>
    </div>

    <div class="flex items-center gap-2 text-text-light/70 dark:text-text-dark/70">
      <Icon name="calendar" class="w-4 h-4 flex-shrink-0" />
      <span>发布于: <FormattedDate date={pubDate} /></span>
    </div>

    <div class="flex items-center gap-2 text-text-light/70 dark:text-text-dark/70">
      <Icon name="refresh" class="w-4 h-4 flex-shrink-0" />
      <span>更新于: <FormattedDate date={displayUpdatedDate} /></span>
    </div>
  </div>
</div>
