---
import { getSiteConfig } from '../utils/config';

const siteConfig = await getSiteConfig();

interface Props {
  siteName?: string;
  avatarUrl?: string;
}

const { siteName = siteConfig.author.name, avatarUrl = siteConfig.author.avatar } = Astro.props;
---

<style is:global>
  #welcome-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
  }

  #welcome-overlay.active {
    display: flex;
  }

  #welcome-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    opacity: 0;
    transform: scale(0.5);
    object-fit: cover;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
  }

  @media (min-width: 768px) {
    #welcome-avatar {
      width: 140px;
      height: 140px;
    }
  }

  #welcome-avatar.animate {
    animation: avatar-reveal 1s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  #welcome-logo {
    font-size: 40px;
    opacity: 0;
    transform: scale(0.5);
  }

  @media (min-width: 768px) {
    #welcome-logo {
      font-size: 60px;
    }
  }

  #welcome-logo.animate {
    animation: logo-reveal 1s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  #welcome-tagline {
    font-size: 1rem;
    opacity: 0;
    transform: translateY(20px);
  }

  @media (min-width: 768px) {
    #welcome-tagline {
      font-size: 1.125rem;
    }
  }

  #welcome-tagline.animate {
    animation: tagline-reveal 0.7s ease-out forwards;
  }

  #welcome-greeting {
    opacity: 0;
    transform: translateY(20px);
  }

  #welcome-greeting.animate {
    animation: tagline-reveal 0.7s ease-out forwards;
  }

  #welcome-greeting-inner {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    background-color: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    color: var(--text-light);
    font-size: 1rem;
    font-weight: 600;
  }

  @media (min-width: 768px) {
    #welcome-greeting-inner {
      font-size: 1.125rem;
      padding: 0.625rem 1.5rem;
    }
  }

  .dark #welcome-greeting-inner {
    background-color: rgba(0, 0, 0, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-dark);
  }

  #welcome-overlay.fade-out {
    animation: overlay-fade 0.5s ease-out forwards;
  }

  @keyframes avatar-reveal {
    0% {
      opacity: 0;
      transform: scale(0.5);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes logo-reveal {
    0% {
      opacity: 0;
      transform: scale(0.5);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes tagline-reveal {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes overlay-fade {
    0% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      pointer-events: none;
    }
  }
</style>

<div id="welcome-overlay" class="bg-background-light dark:bg-background-dark">
  <div class="flex flex-col items-center gap-4">
    <img
      id="welcome-avatar"
      src={avatarUrl}
      alt="Avatar"
      crossorigin="anonymous"
    />
    <div
      id="welcome-logo"
      class="font-plus-jakarta font-extrabold tracking-wide text-text-light dark:text-text-dark"
    >
      {siteName}
    </div>
    <div
      id="welcome-tagline"
      class="text-text-light/70 dark:text-text-dark/70"
    >
      {siteConfig.author.slogan}
    </div>
    <div id="welcome-greeting">
      <span id="welcome-greeting-inner"></span>
    </div>
  </div>
</div>
