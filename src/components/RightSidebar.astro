---
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
const defaultCover = '/img/df-cover.webp';

const posts = await getCollection('post', ({ data }) => !data.draft && !data.friends && !data.friendGroups && !data.moments);

// 1. 标签逻辑处理
const allTags = posts.reduce((acc, post) => {
  const tags = post.data.tags || [];
  tags.forEach(tag => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

const sortedTags = Object.entries(allTags).sort((a, b) => b[1] - a[1]);
const allTagsJson = JSON.stringify(sortedTags);

// 2. 网站统计
const siteStartDate = "2021-01-02";

// 计算总字数（预估）
const totalWords = posts.reduce((acc, post) => {
  const bodyLength = post.body?.length || 0;
  return acc + bodyLength;
}, 0);

// 计算总分类数
const allCategories = new Set(posts.map(post => post.data.category).filter(Boolean));
const totalCategories = allCategories.size;

// 3. 准备所有文章的精简数据供前端随机抽取
interface PostSummary {
  id: string;
  originalFileName: string;
  title: string;
  pubDate: string;
  heroImage?: string | { src: string };
  category?: string;
}

const postSummaries: PostSummary[] = posts.map(post => ({
  id: post.id,
  originalFileName: post.id.toLowerCase(),
  title: post.data.title,
  pubDate: post.data.pubDate.toISOString(),
  heroImage: post.data.heroImage || defaultCover,
  category: post.data.category,
}));

// 初始显示由客户端 JS 随机选取，构建时不再预选
import { Icon } from 'astro-icon/components';
---

<aside class="hidden md:block w-[272px] space-y-6">
  <!-- 公告卡片 -->
  <div class="relative overflow-hidden pt-5 px-6 pb-2 bg-card-light dark:bg-card-dark text-text-light dark:text-text-dark rounded-3xl shadow-sm hover:-translate-y-1 hover:shadow-xl transition-all duration-300 border border-transparent hover:border-border-light dark:hover:border-border-dark group/container select-none">
  
  <div class="flex items-center justify-between mb-4 border-b border-border-light dark:border-border-dark pb-3 relative">
    <div class="flex items-center gap-2">
      <span class="w-1.5 h-1.5 rounded-full bg-primary-light dark:bg-primary-dark"></span>
      <h3 class="text-base font-bold tracking-wider text-text-light dark:text-text-dark">
        公告
      </h3>
    </div>
    <span class="text-[10px] tracking-widest text-text-light/40 dark:text-text-dark/40 uppercase font-medium">
      十年之约
    </span>
  </div>

  <div class="space-y-4">
    <div class="inline-block">
      <a href="https://www.foreverblog.cn" target="_blank" rel="noopener noreferrer" class="block opacity-80 hover:opacity-100 transition-all transform hover:scale-[1.02] duration-500 ease-out origin-left">
        <img
          src="/img/logo_en_default.png"
          alt="十年之约"
          class="h-6 w-auto object-contain brightness-95 dark:brightness-110"
        />
      </a>
    </div>

    <p class="text-xs font-normal leading-relaxed text-text-light/50 dark:text-text-dark/50">
      本博客已加入十年之约活动。点击下方的虫洞按钮，即可随机跃迁到其他成员的独立博客。
    </p>

    <a 
      href="https://www.foreverblog.cn/go.html" 
      target="_blank" 
      rel="noopener noreferrer" 
      class="group/btn flex items-center justify-between py-1 relative"
    >
      <div class="flex items-center gap-1">
        <span class="text-xs font-semibold text-text-light/80 dark:text-text-dark/80 group-hover/btn:text-primary-light dark:group-hover/btn:text-primary-dark transition-colors duration-300">
          穿梭虫洞！
        </span>
        <span class="text-xs text-text-light/40 dark:text-text-dark/40 group-hover/btn:text-primary-light dark:group-hover/btn:text-primary-dark transform group-hover/btn:translate-x-1 transition-all duration-300 pl-0.5">&rarr;</span>
      </div>

      <div class="flex-shrink-0 flex items-center transform group-hover/btn:scale-105 transition-transform duration-500 ease-out">
        <img
          src="/img/wormhole_4_tp.gif"
          alt="虫洞"
          width="129"
          height="36"
          class="w-[95px] h-auto dark:hidden object-contain opacity-75 group-hover/btn:opacity-100 transition-opacity duration-300"
        />
        <img
          src="/img/wormhole_2_tp.gif"
          alt="虫洞"
          width="129"
          height="36"
          class="w-[95px] h-auto hidden dark:block object-contain opacity-65 group-hover/btn:opacity-100 transition-opacity duration-300"
        />
      </div>
    </a>
  </div>
</div>
  <!-- 随机推荐卡片 -->
  <div class="pt-5 px-5 pb-2 bg-card-light dark:bg-card-dark rounded-3xl shadow-sm hover:-translate-y-1 hover:shadow-xl transition-all duration-300 border border-transparent hover:border-border-light dark:hover:border-border-dark relative overflow-hidden group/container">
    <div class="absolute -right-16 -top-16 w-40 h-40 bg-primary-light/10 dark:bg-primary-dark/10 rounded-full blur-3xl pointer-events-none transition-all duration-700 group-hover/container:scale-150"></div>

    <div class="flex items-center justify-between mb-2 relative select-none">
      <div class="flex items-center gap-2 relative z-10 pl-0.5">
        <span class="w-[3px] h-3.5 bg-primary-light/40 dark:bg-primary-dark/30 rounded-full transition-all duration-500 group-hover/container:h-4 group-hover/container:bg-primary-light dark:group-hover/container:bg-primary-dark"></span>
        <h3 class="text-base font-bold tracking-normal text-text-light dark:text-text-dark">
          随机推荐
        </h3>
      </div>
    
      <button
        type="button"
        style="outline: none;" class="js-refresh-trigger group p-1.5 rounded-lg text-text-light/40 dark:text-text-dark/40 hover:text-neutral-700 dark:hover:text-neutral-200 hover:bg-black/[0.04] dark:hover:bg-white/[0.04] transition-all duration-300 focus:outline-none active:scale-90 select-none"
        data-posts={JSON.stringify(postSummaries)}
        aria-label="刷新推荐"
      >
        <Icon name="reroll" class="js-refresh-icon w-4 h-4 transition-transform duration-700 ease-[cubic-bezier(0.34,1.56,0.64,1)] group-hover:rotate-180 group-active:rotate-0 group-active:duration-0 group-active:transition-none" />
      </button>
    </div>

    <ul class="js-posts-list-container">
    </ul>
  </div>

  <!-- 标签卡片 -->
  <div class="p-6 bg-card-light dark:bg-card-dark rounded-3xl shadow-sm hover:-translate-y-1 hover:shadow-xl transition-all duration-300 border border-transparent hover:border-border-light dark:hover:border-border-dark">
    <div class="relative mb-5">
      <h3 class="inline-block text-lg font-black italic tracking-tight text-neutral-800 dark:text-neutral-100 after:content-[''] after:absolute after:left-0 after:bottom-0 after:h-2 after:w-full after:bg-yellow-400/30 dark:after:bg-indigo-500/40 after:-z-10">
        TAGS
      </h3>
    </div>

    <div class="js-tags-container line-clamp-5 [display:-webkit-box] [-webkit-box-orient:vertical] overflow-hidden" data-tags={allTagsJson}></div>
  </div>

  <!-- RSS订阅卡片 -->
  <div class="relative overflow-hidden p-6 bg-card-light dark:bg-card-dark rounded-3xl shadow-sm hover:-translate-y-1 hover:shadow-xl transition-all duration-300 border border-transparent hover:border-border-light dark:hover:border-border-dark group/rsscard select-none flex flex-col justify-between min-h-[180px]">
    <div class="relative">
      <div class="absolute -right-2 -top-6 text-7xl font-black italic tracking-tighter text-text-light/[0.03] dark:text-text-dark/5 select-none pointer-events-none font-sans">
        订阅
      </div>
      <h2 class="text-xl font-extrabold tracking-tight text-neutral-800 dark:text-neutral-100 leading-tight">
        利用 RSS 订阅<br/>获取最直接的文章推送
      </h2>
      <p class="mt-4 text-xs text-text-light/50 dark:text-text-dark/40 font-normal">
        点击滑块，即可复制 RSS 链接。
      </p>
    </div>

    <div class="mt-5">
      <button
        type="button"
        data-clipboard-text="https://log.1k.ink/rss.xml"
        onclick="
          const self = this;
          if (self.classList.contains('is-success')) return;
          self.classList.add('is-success');

          navigator.clipboard.writeText(self.getAttribute('data-clipboard-text')).then(() => {
            setTimeout(() => {
              self.classList.remove('is-success');
            }, 2200);
          });
        "
        class="group/btn w-full h-11 relative rounded-2xl bg-neutral-100 dark:bg-neutral-950/80 border border-neutral-200/50 dark:border-neutral-800/80 p-1 cursor-pointer overflow-hidden select-none active:scale-[0.98] transition-all duration-300"
      >
        <div class="absolute inset-y-1 inset-x-2 flex items-center justify-between pointer-events-none select-none z-0">
          <div class="flex gap-1.5 pl-4 opacity-0 group-hover/btn:opacity-100 transition-opacity duration-300 group-[.is-success]/btn:opacity-0">
            <span class="w-[2px] h-2 bg-neutral-300 dark:bg-neutral-800 rounded-full"></span>
            <span class="w-[2px] h-2 bg-neutral-300 dark:bg-neutral-800 rounded-full"></span>
            <span class="w-[2px] h-2 bg-neutral-300 dark:bg-neutral-800 rounded-full"></span>
          </div>
          <div class="flex gap-1.5 pr-4 transition-all duration-300 group-[.is-success]/btn:opacity-0">
            <span class="w-[2px] h-2 bg-neutral-300 dark:bg-neutral-800 rounded-full"></span>
            <span class="w-[2px] h-2 bg-neutral-300 dark:bg-neutral-800 rounded-full"></span>
            <span class="w-[2px] h-2 bg-neutral-300 dark:bg-neutral-800 rounded-full"></span>
          </div>
        </div>

        <div class="absolute left-4 top-1/2 -translate-y-1/2 opacity-0 group-[.is-success]/btn:opacity-30 transition-opacity duration-300 pointer-events-none text-neutral-400 dark:text-neutral-600 text-xs z-0">
          <span>RSS.xml</span>
        </div>
        <div class="h-full w-2/3 rounded-xl bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800/80 shadow-sm flex items-center justify-center transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] transform group-hover/btn:translate-x-[50%] group-hover/btn:bg-[#f26522] group-hover/btn:border-transparent group-[.is-success]/btn:translate-x-[223%] group-[.is-success]/btn:w-[30%] group-[.is-success]/btn:bg-neutral-200 dark:group-[.is-success]/btn:bg-neutral-800 group-[.is-success]/btn:border-transparent group-[.is-success]/btn:shadow-none z-10">
          <div class="relative w-full h-full flex items-center justify-center">
            <span class="absolute text-xs font-bold text-neutral-600 dark:text-neutral-400 group-hover/btn:text-white tracking-tight transition-all duration-200 group-[.is-success]/btn:opacity-0 group-[.is-success]/btn:scale-75">
              log.1k.ink/rss.xml
            </span>
            <div class="absolute opacity-0 scale-75 transition-all duration-300 group-[.is-success]/btn:opacity-100 group-[.is-success]/btn:scale-100 flex items-center justify-center text-neutral-500 dark:text-neutral-400">
              <Icon name="check" class="w-4 h-4" />
            </div>
          </div>
        </div>
      </button>
      <div class="mt-3 text-[10px] text-text-light/40 dark:text-text-dark/40 font-normal text-center">
        支持 Feedly、Inoreader、Reeder 等
      </div>
    </div>
  </div>

  <!-- 博客统计卡片 -->
  <div class="relative overflow-hidden p-6 bg-card-light dark:bg-card-dark text-text-light dark:text-text-dark rounded-3xl shadow-sm hover:-translate-y-1 hover:shadow-xl transition-all duration-300 border border-transparent hover:border-border-light dark:hover:border-border-dark select-none min-h-[230px] flex flex-col justify-between group/statcard">
    <div class="absolute -right-6 -bottom-10 text-[140px] font-black italic tracking-tighter text-neutral-800/[0.03] dark:text-neutral-100/[0.02] select-none pointer-events-none transform origin-bottom-right transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover/statcard:scale-110 group-hover/statcard:translate-x-2 group-hover/statcard:text-primary-light/[0.04] dark:group-hover/statcard:text-primary-dark/[0.03]">
      字
    </div>
    <div class="relative z-10">
      <div class="flex items-baseline gap-1">
        <span class="text-5xl font-black font-mono tracking-tighter text-neutral-800 dark:text-neutral-100 js-count-up" data-target={(totalWords / 10000).toFixed(1)}>0</span>
        <span class="text-sm font-black text-text-light/50 dark:text-text-dark/40 ml-1 tracking-widest">万字全站文本</span>
      </div>
      <div class="h-[2px] w-12 bg-primary-light/60 dark:bg-primary-dark/50 mt-3 rounded-full transition-all duration-500 group-hover/statcard:w-20"></div>
    </div>

    <div class="grid grid-cols-5 gap-2 items-end pt-6 pb-2 relative z-10">
      <a href="/archives" class="col-span-3 group/item cursor-pointer block">
        <span class="text-[10px] font-normal tracking-widest text-text-light/40 dark:text-text-dark/40 block mb-1">已发表文章</span>
        <div class="flex items-baseline gap-1">
          <div class="text-2xl font-black font-mono tracking-tight text-neutral-700 dark:text-neutral-300 group-hover/item:text-primary-light dark:group-hover/item:text-primary-dark transition-transform js-count-up" data-target={posts.length}>0</div>
          <span class="text-[10px] font-bold text-text-light/30 dark:text-text-dark/30">篇</span>
        </div>
        <div class="h-[2px] w-4 bg-neutral-200 dark:bg-neutral-800 mt-2 group-hover/item:w-8 group-hover/item:bg-primary-light dark:group-hover/item:bg-primary-dark transition-all duration-300"></div>
      </a>

      <div class="col-span-2 flex flex-col gap-2.5 items-end justify-end border-l border-neutral-200/40 dark:border-neutral-800/40 pr-1">
        <a href="/categories" class="group/sub cursor-pointer flex items-baseline gap-2 text-right">
          <span class="text-[10px] font-normal tracking-wider text-text-light/40 dark:text-text-dark/40 group-hover/sub:text-text-light dark:group-hover/sub:text-text-dark transition-transform">分类</span>
          <span class="text-base font-black font-mono text-neutral-600 dark:text-neutral-400 group-hover/sub:text-primary-light dark:group-hover/sub:text-primary-dark transition-transform js-count-up" data-target={totalCategories}>0</span>
        </a>
        <a href="/tags" class="group/sub cursor-pointer flex items-baseline gap-2 text-right">
          <span class="text-[10px] font-normal tracking-wider text-text-light/40 dark:text-text-dark/40 group-hover/sub:text-text-light dark:group-hover/sub:text-text-dark transition-transform">标签</span>
          <span class="text-base font-black font-mono text-neutral-600 dark:text-neutral-400 group-hover/sub:text-primary-light dark:group-hover/sub:text-primary-dark transition-transform js-count-up" data-target={Object.keys(allTags).length}>0</span>
        </a>
      </div>
    </div>

    <div class="mt-4 pt-3.5 border-t border-neutral-200/40 dark:border-neutral-800/40 flex items-center justify-between text-xs relative z-10">
      <div class="flex items-center gap-2 text-text-light/40 dark:text-text-dark/40 tracking-widest text-[11px]">
        <span class="w-1.5 h-1.5 bg-neutral-300 dark:bg-neutral-700 rounded-none"></span>
        持续运行
      </div>
      <div class="font-mono text-xs text-text-light/60 dark:text-text-dark/50">
        <span class="text-sm text-neutral-800 dark:text-neutral-100 font-black js-count-up" data-target="0" data-start={siteStartDate}>0</span> 天
      </div>
    </div>
  </div>
</aside>

<script>
  interface PostData {
    pubDate: string;
    originalFileName: string;
    title: string;
    heroImage?: string;
    category?: string;
  }

  function spinRefreshIcon(btn: HTMLElement) {
    const icons = btn.querySelectorAll<HTMLElement>('.js-refresh-icon');
    icons.forEach((el) => {
      el.classList.remove('is-spinning');
      void el.offsetWidth;
      el.classList.add('is-spinning');
      el.addEventListener('animationend', () => el.classList.remove('is-spinning'), { once: true });
    });
  }

  function renderRandomPosts(listContainer: HTMLElement, rawData: string) {
    try {
      const allPosts: PostData[] = JSON.parse(rawData);
      const shuffled = [...allPosts];
      for (let i = shuffled.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
      }
      const selected = shuffled.slice(0, 3);

      listContainer.innerHTML = selected.map((post, index) => {
        const date = new Date(post.pubDate).toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });

        const serialNumber = String(index + 1).padStart(2, '0');
        const displayImage = post.heroImage || '/img/df-cover.webp';
        const categoryHtml = post.category ? `<span class="text-text-light/35 dark:text-text-dark/25"># ${post.category}</span>` : '';

        return `
          <li class="group/item">
            <a href="/p/${post.originalFileName}" class="block relative py-5 transition-all duration-300">
              <div class="absolute right-0 top-1/2 -translate-y-1/2 w-24 h-16 rounded-xl overflow-hidden pointer-events-none opacity-[0.04] dark:opacity-[0.08] scale-100 group-hover/item:opacity-[0.22] dark:group-hover/item:opacity-[0.25] group-hover/item:scale-105 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] z-0">
                <div class="w-full h-full bg-center bg-cover grayscale-[30%] group-hover/item:grayscale-0 transition-all duration-500" style="background-image:url(${displayImage})"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent opacity-0 group-hover/item:opacity-100 duration-500"></div>
              </div>
              <div class="flex items-start gap-4 relative z-10 w-full">
                <span class="font-mono text-xl font-light text-text-light/15 dark:text-text-dark/15 group-hover/item:text-neutral-400 dark:group-hover/item:text-neutral-500 transition-colors duration-300 pt-0.5 shrink-0">
                  ${serialNumber}
                </span>
                <div class="flex-1 min-w-0 w-full">
                  <div class="flex items-center gap-2 text-[10px] tracking-wider text-text-light/35 dark:text-text-dark/25 mb-1">
                    ${categoryHtml}
                    ${date}
                  </div>
                  <p class="text-sm font-medium tracking-tight text-neutral-500 dark:text-neutral-400 group-hover/item:text-neutral-700 dark:group-hover/item:text-neutral-100 duration-300 line-clamp-1 group-hover/item:translate-x-1 transition-transform leading-snug">
                    ${post.title}
                  </p>
                </div>
              </div>
            </a>
          </li>
        `;
      }).join('');

      listContainer.style.opacity = '1';
    } catch (e) {
      console.error('[RandomPosts] Render error:', e);
      listContainer.style.opacity = '1';
    }
  }

  // 页面加载时客户端随机渲染
  function initRandomPosts() {
    document.querySelectorAll('.js-posts-list-container').forEach(listContainer => {
      const card = listContainer.closest('div')?.parentElement;
      const btn = card?.querySelector('.js-refresh-trigger') as HTMLElement | null;
      if (!btn) return;
      const rawData = btn.getAttribute('data-posts');
      if (!rawData) return;
      renderRandomPosts(listContainer as HTMLElement, rawData);
    });
  }

  function refresh(btn: HTMLElement) {
    spinRefreshIcon(btn);
    const cardContainer = btn.closest('div')?.parentElement;
    const listContainer = cardContainer?.querySelector('.js-posts-list-container') as HTMLElement | null;
    const rawData = btn.getAttribute('data-posts');

    if (!listContainer || !rawData) return;
    listContainer.style.transition = 'opacity 300ms cubic-bezier(0.4, 0, 0.2, 1)';
    listContainer.style.opacity = '0';

    setTimeout(() => {
      renderRandomPosts(listContainer, rawData);
    }, 200);
  }

  const onGlobalClick = (e: MouseEvent) => {
    const btn = (e.target as HTMLElement).closest('.js-refresh-trigger') as HTMLElement | null;
    if (btn) refresh(btn);
  };

  document.addEventListener('click', onGlobalClick);
  document.addEventListener('astro:page-load', initRandomPosts);
  document.addEventListener('astro:after-swap', () => {
    document.removeEventListener('click', onGlobalClick);
    document.addEventListener('click', onGlobalClick);
  });

  const ANIMATION_DURATION = 1500;
  function animateNumber(element: HTMLElement, target: string) {
    const isDecimal = target.includes('.');
    const numericTarget = parseFloat(target);
    const startTime = performance.now();

    function update(currentTime: number) {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / ANIMATION_DURATION, 1);
      const easeProgress = 1 - Math.pow(1 - progress, 4);
      const currentValue = numericTarget * easeProgress;

      if (isDecimal) {
        element.textContent = currentValue.toFixed(1);
      } else {
        element.textContent = String(Math.floor(currentValue));
      }

      if (progress < 1) requestAnimationFrame(update);
      else element.textContent = target;
    }
    requestAnimationFrame(update);
  }

  const countUpObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const element = entry.target as HTMLElement;
        let target = element.getAttribute('data-target');

        const startDateStr = element.getAttribute('data-start');
        if (startDateStr) {
          const startDate = new Date(startDateStr);
          const today = new Date();
          const realDays = Math.floor((today.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24));
          target = realDays.toString();
        }

        if (target && target !== '0') {
          animateNumber(element, target);
          countUpObserver.unobserve(element);
        }
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

  function initCountUpElements() {
    const countElements = document.querySelectorAll('.js-count-up');
    countElements.forEach((element) => countUpObserver.observe(element));
  }

  document.addEventListener('astro:page-load', initCountUpElements);

  function renderRandomTags() {
    const containers = document.querySelectorAll('.js-tags-container');
    containers.forEach(container => {
      const rawData = container.getAttribute('data-tags');
      if (!rawData) return;

      try {
        const allTags: [string, number][] = JSON.parse(rawData);

        const shuffled = [...allTags];
        for (let i = shuffled.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
        }

        container.innerHTML = shuffled.map(([tag, count], index) => {
          const isLast = index === shuffled.length - 1;
          return `
            <span class="inline-block white-space-nowrap mr-2 mb-2">
              <a href="/tags/${tag}" class="group inline-flex items-baseline text-sm font-medium text-neutral-600 dark:text-neutral-400 hover:text-black dark:hover:white transition-transform duration-200">
                <span class="group-hover:underline decoration-1 underline-offset-4">${tag}</span>
                <sup class="text-[9px] font-mono opacity-40 ml-0.5 group-hover:opacity-100 group-hover:text-amber-500 transition-transform">${count}</sup>
              </a>
              ${!isLast ? `<span class="text-neutral-300 dark:text-neutral-700 font-light select-none ml-2">/</span>` : ''}
            </span>
          `;
        }).join('');
      } catch (e) {}
    });
  }

  document.addEventListener('astro:page-load', renderRandomTags);
</script>

