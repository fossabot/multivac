---
import { getSiteConfig } from '../utils/config';

const siteConfig = await getSiteConfig();

interface Props {
  elId?: string;
}

const { elId: customElId } = Astro.props;

const envId = siteConfig.comment.twikoo.envId;
const TWIKOO_VERSION = siteConfig.comment.twikoo.version;

const pageKey = (() => {
  try {
    return Astro.url.pathname || '/';
  } catch {
    return '/';
  }
})();

const elId = customElId ?? `tcomment-${pageKey.replace(/[^a-zA-Z0-9]+/g, '-').replace(/^-+|-+$/g, '') || 'root'}`;
---

<div 
  id={elId} 
  class="twikoo" 
  data-twikoo-env-id={envId}
  data-version={TWIKOO_VERSION}
>

  <div class="twikoo-loading text-sm text-neutral-400 text-center py-8">
    正在加载评论区...
  </div>
</div>

<script>
  declare global {
    interface Window {
      twikoo?: { init: (options: { envId: string; el: string; lang: string; path: string }) => void };
      __twikooLoader?: { promise: Promise<void> | null };
      __twikooAstro?: { listeners: boolean };
    }
  }

  function getTwikooMounts(): Element[] {
    return Array.from(document.querySelectorAll('.twikoo[data-twikoo-env-id]'));
  }

  function waitForTwikooGlobal(timeoutMs = 3000): Promise<void> {
    const start = performance.now();
    return new Promise((resolve, reject) => {
      const tick = () => {
        if (window.twikoo && typeof window.twikoo.init === 'function') return resolve();
        if (performance.now() - start > timeoutMs) return reject(new Error('twikoo global timeout'));
        requestAnimationFrame(tick);
      };
      tick();
    });
  }

  function getUrls() {
    const mount = document.querySelector('.twikoo[data-version]');
    const version = mount?.getAttribute('data-version') || '1.7.13';
    
    return {
      js: `https://registry.npmmirror.com/twikoo/${version}/files/dist/twikoo.nocss.js`,
      css: `https://registry.npmmirror.com/twikoo/${version}/files/dist/twikoo.css`
    };
  }

  function ensureTwikooCssLoaded(): void {
    if (document.getElementById('twikoo-persistent-style')) return;

    const { css } = getUrls();
    const link = document.createElement('link');
    link.id = 'twikoo-persistent-style';
    link.rel = 'stylesheet';
    link.href = css;
    link.setAttribute('data-astro-transition-persist', 'twikoo-style');
    document.head.appendChild(link);
  }

  async function ensureTwikooLoaded(): Promise<void> {
    ensureTwikooCssLoaded();

    if (window.twikoo && typeof window.twikoo.init === 'function') return;
    window.__twikooLoader = window.__twikooLoader || { promise: null };
    if (window.__twikooLoader!.promise) {
      await window.__twikooLoader!.promise;
      return;
    }

    window.__twikooLoader!.promise = new Promise<void>((resolve, reject) => {
      const existing = document.getElementById('twikoo-script');
      if (existing) {
        existing.setAttribute('data-astro-transition-persist', 'twikoo-js');
        if (window.twikoo && typeof window.twikoo.init === 'function') return resolve();

        existing.addEventListener('load', () => resolve(), { once: true });
        existing.addEventListener('error', () => reject(new Error('twikoo script load error')), { once: true });
        return;
      }

      const { js } = getUrls();
      const script = document.createElement('script');
      script.id = 'twikoo-script';
      script.src = js;
      script.async = true;
      script.setAttribute('data-astro-transition-persist', 'twikoo-js');
      script.onload = () => resolve();
      script.onerror = (e) => {
        window.__twikooLoader!.promise = null;
        reject(e);
      };
      document.head.appendChild(script);
    });

    await window.__twikooLoader!.promise;
    await waitForTwikooGlobal();
  }

  function initTwikooForMount(mountEl: Element) {
    if (!window.twikoo || typeof window.twikoo.init !== 'function') return;
    if (!(mountEl instanceof Element)) return;

    const envId = mountEl.getAttribute('data-twikoo-env-id');
    if (!envId || !mountEl.id) return;

    const loader = mountEl.querySelector('.twikoo-loading');
      if (loader) {
        loader.remove();
      }

    window.twikoo.init({
      envId,
      el: `#${mountEl.id}`,
      lang: 'zh-CN',
      path: window.location.pathname,
    });
  }

  function boot() {
    const mounts = getTwikooMounts();
    if (!mounts.length) return;

    const initializedMounts = new Set<string>();
    document.querySelectorAll('.twikoo[data-twikoo-env-id]').forEach(el => {
      if (el.querySelector('.tk-comments')) {
        initializedMounts.add(el.id);
      }
    });

    const init = () => {
      ensureTwikooLoaded()
        .then(() => {
          requestAnimationFrame(() =>
            requestAnimationFrame(() => {
              for (const m of mounts) {
                if (!initializedMounts.has(m.id)) {
                  initTwikooForMount(m);
                }
              }
            }),
          );
        })
        .catch(() => {});
    };

    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(() => init(), { timeout: 2000 });
    } else {
      setTimeout(init, 100);
    }
  }

  if (!window.__twikooAstro) {
    window.__twikooAstro = { listeners: true };
    document.addEventListener('astro:page-load', boot);
    document.addEventListener('astro:after-swap', boot);
  }
</script>
