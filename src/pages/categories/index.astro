---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const posts = await getCollection('post', ({ data }) => !data.draft && !data.friends && !data.friendGroups && !data.moments);

const postsByCategory = posts.reduce((acc, post) => {
  const category = post.data.category;
  if (category) {
    if (!acc[category]) {
      acc[category] = [];
    }
    acc[category].push(post);
  }
  return acc;
}, {} as Record<string, CollectionEntry<'post'>[]>);

const categories = Object.keys(postsByCategory).sort((a, b) => postsByCategory[b].length - postsByCategory[a].length);
import { Icon } from 'astro-icon/components';
---

<MainLayout title="全部分类" description="查看博客的所有分类">
  <section class="max-w-[1340px] mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl font-bold text-text-light dark:text-text-dark mb-8 text-center">全部分类</h1>
      <div class="flex flex-wrap gap-4 justify-center">
        {categories.map(category => {
          const categoryPosts = postsByCategory[category as string] || [];
          return (
            <a
              href={`/categories/${category}`}
              class="group relative inline-flex items-center gap-3 px-6 py-4 rounded-2xl bg-card-light dark:bg-card-dark hover:shadow-lg hover:-translate-y-1 transition-all duration-300 will-change-transform"
            >
              <div class="flex items-center gap-3">
                <Icon name="folder" class="w-5 h-5 text-primary-light dark:text-primary-dark" />
                <span class="text-base font-medium text-text-light dark:text-text-dark group-hover:text-primary-light dark:group-hover:text-primary-dark transition-colors">{category}</span>
              </div>
              <span class="px-3 py-1 bg-badge-light dark:bg-badge-dark text-text-light/70 dark:text-text-dark/70 text-sm font-medium rounded-full">
                {categoryPosts.length}
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</MainLayout>
