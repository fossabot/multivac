---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('post', ({ data, id }) => !data.draft && !id.startsWith('about/') && !data.friends && !data.friendGroups && !data.moments && !data.watching);

const allTags = posts.reduce((acc, post) => {
  const tags = post.data.tags || [];
  tags.forEach(tag => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

const sortedTags = Object.entries(allTags).sort((a, b) => b[1] - a[1]);
---

<MainLayout title="全部标签" description="查看博客的所有标签">
  <section class="section-container pt-24 pb-16">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl font-bold text-text-light dark:text-text-dark mb-8 text-center">全部标签</h1>
      <div class="flex flex-wrap gap-3 justify-center">
        {sortedTags.map(([tag, count]) => (
          <a
            href={`/tags/${tag}`}
            class="group relative inline-flex items-center rounded-full overflow-hidden hover:scale-105 transition-transform duration-200 will-change-transform"
          >
            <span class="px-5 py-3 bg-badge-light text-text-light dark:bg-badge-dark dark:text-text-dark text-base font-medium">
              {tag}
            </span>
            <span class="px-4 py-3 bg-divider-light text-text-light dark:bg-hover-dark dark:text-text-dark text-base font-medium opacity-60">
              {count}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
