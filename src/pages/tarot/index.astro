  { name: '倒吊人', nameEn: 'THE HANGED MAN', num: 'XII', gradient: 'from-blue-400 to-indigo-500', lightGradient: 'from-blue-600 to-indigo-600', glow: 'rgba(96,165,250,0.4)', lightGlow: 'rgba(96,165,250,0.15)', upright: '牺牲、换位思考、等待、领悟', reversed: '无谓牺牲、拖延、抗拒改变', uprightAdvice: '换个角度看问题，等待也是智慧', reversedAdvice: '停止无意义的等待，主动做出改变' },
