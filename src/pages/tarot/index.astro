  { name: '恶魔', nameEn: 'THE DEVIL', num: 'XV', gradient: 'from-red-500 to-purple-700', lightGradient: 'from-red-700 to-purple-800', glow: 'rgba(168,85,247,0.4)', lightGlow: 'rgba(168,85,247,0.15)', upright: '束缚、诱惑、欲望、物质执念', reversed: '释放、觉醒、打破束缚', uprightAdvice: '审视执念，不要被欲望控制', reversedAdvice: '挣脱束缚的时机已到，勇敢解放自己' },
  { name: '塔', nameEn: 'THE TOWER', num: 'XVI', gradient: 'from-red-400 to-orange-600', lightGradient: 'from-red-600 to-orange-700', glow: 'rgba(248,113,113,0.4)', lightGlow: 'rgba(248,113,113,0.15)', upright: '突变、崩塌、真相揭露', reversed: '余震未消、隐患尚在、缓慢重建', uprightAdvice: '废墟之上，才能重建更好的生活', reversedAdvice: '最猛烈的风暴已过，耐下心来一件件修补' },
  { name: '星星', nameEn: 'THE STAR', num: 'XVII', symbol: '⭐', gradient: 'from-yellow-300 to-amber-400', lightGradient: 'from-yellow-500 to-amber-500', glow: 'rgba(252,211,77,0.4)', lightGlow: 'rgba(252,211,77,0.15)', upright: '希望、灵感、宁静、祝福', reversed: '失去信心、迷失方向', uprightAdvice: '相信希望，星光终会指引你', reversedAdvice: '重新连接内心的光，希望从未远离' },
  { name: '月亮', nameEn: 'THE MOON', num: 'XVIII', gradient: 'from-indigo-300 to-purple-500', lightGradient: 'from-indigo-500 to-purple-600', glow: 'rgba(165,180,252,0.4)', lightGlow: 'rgba(165,180,252,0.15)', upright: '幻象、潜意识、直觉、不安', reversed: '走出迷雾、真相显现', uprightAdvice: '面对内心的恐惧，真相就在迷雾后', reversedAdvice: '迷雾正在散去，准备好迎接真相' },
  { name: '太阳', nameEn: 'THE SUN', num: 'XIX', gradient: 'from-yellow-400 to-orange-400', lightGradient: 'from-yellow-600 to-orange-500', glow: 'rgba(250,204,21,0.5)', lightGlow: 'rgba(250,204,21,0.2)', upright: '成功、快乐、活力、光明', reversed: '短暂挫折、过度乐观', uprightAdvice: '尽情绽放，今天属于你', reversedAdvice: '阳光暂时被遮挡，但温暖仍在' },
  { name: '审判', nameEn: 'JUDGEMENT', num: 'XX', gradient: 'from-rose-400 to-pink-500', lightGradient: 'from-rose-600 to-pink-600', glow: 'rgba(251,113,133,0.4)', lightGlow: 'rgba(251,113,133,0.15)', upright: '觉醒、重生、审视、召唤', reversed: '自我怀疑、拒绝成长', uprightAdvice: '审视过去，迎接内心的召唤', reversedAdvice: '停止自我否定，允许自己成长' },
  { name: '世界', nameEn: 'THE WORLD', num: 'XXI', gradient: 'from-emerald-400 to-violet-500', lightGradient: 'from-emerald-600 to-violet-600', glow: 'rgba(52,211,153,0.4)', lightGlow: 'rgba(52,211,153,0.15)', upright: '圆满、完成、成就、和谐', reversed: '美中不足、延迟圆满、最后一步', uprightAdvice: '一切圆满，享受此刻的成就', reversedAdvice: '只差最后的临门一脚，耐心补齐最后一块拼图' },
];

const today = new Date();
const dateStr = `${today.getFullYear()}.${String(today.getMonth() + 1).padStart(2, '0')}.${String(today.getDate()).padStart(2, '0')}`;
const weekDays = ['日', '一', '二', '三', '四', '五', '六'];
const weekDay = weekDays[today.getDay()];

// 默认占位（在 JavaScript 部分随机覆盖）
const card = tarotCards[0];
import { Icon } from 'astro-icon/components';
---

<MainLayout title="cyberTarot()" description="A Pseudo-Random Tarot Generator">
  <section class="tarot-page min-h-[85vh] flex flex-col items-center justify-center px-4 pt-24 pb-16">
    
    <div class="text-center mb-8 relative z-10 font-mono select-none">
      <h2 class="text-xl font-bold tracking-tight text-black/80 dark:text-white/90">
        <span class="text-blue-500 dark:text-sky-400">cyber</span>Tarot<span class="text-amber-500/80 font-normal">()</span>
      </h2>
      <p class="text-[10px] text-black/30 dark:text-white/30 uppercase tracking-[0.2em] mt-1.5">
        // status: <span class="text-emerald-500/80">random_seed_loaded</span>
      </p>
    </div>

    <div id="tarot-data" class="hidden" data-cards={JSON.stringify(tarotCards)}></div>
    
    <div class="w-full max-w-md relative z-10">
      <div id="tarot-scene" class="tarot-scene">
        <div id="fortune-card" class="tarot-card-inner">

          <div class="tarot-face tarot-face-front">
            <div class="flex flex-col items-center justify-center h-full gap-6">
              <div class="relative">
                <div class="tarot-back-pattern w-28 h-40 sm:w-32 sm:h-44 rounded-xl flex items-center justify-center border border-amber-400/20 dark:border-amber-400/10 relative overflow-hidden">
                  <div class="absolute inset-2 border border-amber-400/10 rounded-lg"></div>
                  <div class="absolute inset-4 border border-amber-400/5 rounded-md"></div>
                  <div class="relative z-10 text-center">
                    <div class="text-amber-500/20 text-3xl mb-1">✦</div>
                    <div class="text-amber-600/20 text-[8px] tracking-[0.3em] font-mono uppercase">System</div>
                  </div>
                </div>
                <div class="absolute -inset-4 rounded-2xl border border-amber-400/10 dark:border-amber-400/5 animate-ping" style="animation-duration: 3s;"></div>
              </div>
              <div class="text-center">
                <p class="text-black/30 dark:text-white/30 text-xs font-mono tracking-widest mb-1.5">{dateStr} · 周{weekDay}</p>
                <p class="text-black/50 dark:text-white/60 text-sm font-medium">执行随机扰动以开始</p>
              </div>
            </div>
          </div>

          <div class="tarot-face tarot-face-back">
            <div class="tarot-glow" style={`--glow-color: ${card.glow}; --glow-color-light: ${card.lightGlow}`}></div>

            <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none overflow-hidden z-0">
              <div class="tarot-card-bg-text text-7xl sm:text-8xl font-black tracking-tighter uppercase opacity-[0.04] dark:opacity-[0.06] font-sans text-center px-4 leading-none">
                {card.nameEn}
              </div>
            </div>

            <div class="relative z-10 p-8 sm:p-10 flex flex-col justify-between h-full min-h-[480px] sm:min-h-[500px]">
              <div class="flex items-center justify-between font-mono text-[10px] tracking-wider text-black/30 dark:text-white/30">
                <span>{dateStr}</span>
                <span>SYS_VIBE_REF</span>
              </div>

              <div class="text-center my-auto py-4">
                <div class="tarot-card-num text-black/20 dark:text-white/20 text-xs font-mono tracking-[0.4em] mb-2">{card.num}</div>
                <div class="tarot-card-name inline-block text-4xl sm:text-5xl font-black bg-gradient-to-r bg-clip-text text-transparent mb-4 leading-tight">
                  {card.name}
                </div>
                
                <div>
                  <div class="tarot-position-tag inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-mono tracking-wider mb-4 transition-all duration-300">
                    <span class="tarot-position-dot w-1 h-1 rounded-full"></span>
                    <span class="tarot-position-label">正位</span>
                  </div>
                </div>
                
                <p class="tarot-card-meaning text-black/60 dark:text-white/70 text-sm sm:text-base leading-relaxed max-w-[280px] mx-auto font-medium">{card.upright}</p>
              </div>

              <div class="mt-auto px-4 py-3.5 rounded-xl bg-black/[0.02] dark:bg-white/[0.02] border border-black/[0.05] dark:border-white/[0.05] text-center">
                <span class="text-black/30 dark:text-white/30 text-[9px] font-mono tracking-[0.2em] uppercase">Ref_Advice</span>
                <p class="tarot-card-advice text-black/60 dark:text-white/70 text-sm font-medium mt-1.5 leading-relaxed">{card.uprightAdvice}</p>
              </div>
            </div>
          </div>

        </div>
      </div>

      <div id="tarot-actions" class="mt-8 flex items-center justify-center gap-3 opacity-0 transition-opacity duration-500">
        <button id="tarot-redraw" class="group flex items-center gap-2 px-5 py-2 rounded-full font-mono text-xs bg-black/[0.03] dark:bg-white/5 border border-black/[0.06] dark:border-white/10 hover:border-blue-400/40 dark:hover:border-sky-400/30 hover:bg-blue-50/30 dark:hover:bg-sky-400/5 transition-all duration-300 text-black/40 dark:text-white/50 hover:text-blue-600 dark:hover:text-sky-400">
          <Icon name="refresh" class="w-3.5 h-3.5 transition-transform duration-700 group-hover:rotate-180" />
          rerun_random_seed()
        </button>
      </div>

      <div id="tarot-particles" class="tarot-particles"></div>
    </div>
  </section>
</MainLayout>

<script>
  function initTarot() {
    const scene = document.getElementById('tarot-scene');
    const cardEl = document.getElementById('fortune-card');
    const actions = document.getElementById('tarot-actions');
    const particles = document.getElementById('tarot-particles');
    const dataEl = document.getElementById('tarot-data') as HTMLElement;
    let flipped = false;

    if (!cardEl || !scene || !dataEl) return;

    const cards = JSON.parse(dataEl.dataset.cards || '[]');

    scene.addEventListener('click', () => {
      if (flipped) return;
      flipped = true;
      cardEl.classList.add('flipped');

      setTimeout(() => {
        if (actions) actions.style.opacity = '1';
      }, 400);
    });

    function generateTarot() {
      const card = cards[Math.floor(Math.random() * cards.length)];
      const isUpright = Math.random() > 0.5;
      return { card, isUpright };
    }

    function updateCard(data: ReturnType<typeof generateTarot>) {
      const isDark = document.documentElement.classList.contains('dark');
      const { card, isUpright } = data;

      // 1. 动态弥散光晕
      const glow = document.querySelector('.tarot-glow') as HTMLElement;
      if (glow) {
        glow.style.setProperty('--glow-color', card.glow);
        glow.style.setProperty('--glow-color-light', card.lightGlow);
      }

      // 2. 动态视觉大英文背景（去AI味核心）
      const bgTextEl = document.querySelector('.tarot-card-bg-text') as HTMLElement;
      if (bgTextEl) {
        bgTextEl.textContent = card.nameEn;
        // 如果是逆位，让背景大字一同微调或倒置增强趣味
        bgTextEl.style.transform = isUpright ? 'none' : 'rotate(180deg)';
      }

      // 3. 牌名与动态渐变色绑定
      const nameEl = document.querySelector('.tarot-card-name') as HTMLElement;
      if (nameEl) {
        nameEl.textContent = card.name;
        nameEl.className = `tarot-card-name inline-block text-4xl sm:text-5xl font-black bg-gradient-to-r ${isDark ? card.gradient : card.lightGradient} bg-clip-text text-transparent mb-4 leading-tight`;
      }

      const numEl = document.querySelector('.tarot-card-num') as HTMLElement;
      if (numEl) numEl.textContent = card.num;

      // 4. 清洁的 Tag 样式重构逻辑
      const positionTag = document.querySelector('.tarot-position-tag') as HTMLElement;
      const dot = document.querySelector('.tarot-position-dot') as HTMLElement;
      const label = document.querySelector('.tarot-position-label') as HTMLElement;
      
      if (positionTag && dot && label) {
        label.textContent = isUpright ? '正位 / Normal' : '逆位 / Inverted';
        
        if (isUpright) {
          positionTag.className = 'tarot-position-tag inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-mono tracking-wider mb-4 bg-emerald-500/[0.06] dark:bg-emerald-400/[0.06] text-emerald-600 dark:text-emerald-400 border border-emerald-500/[0.1]';
          dot.className = 'tarot-position-dot w-1 h-1 rounded-full bg-emerald-500 dark:bg-emerald-400';
        } else {
          positionTag.className = 'tarot-position-tag inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-mono tracking-wider mb-4 bg-rose-500/[0.06] dark:bg-rose-400/[0.06] text-rose-600 dark:text-rose-400 border border-rose-500/[0.1]';
          dot.className = 'tarot-position-dot w-1 h-1 rounded-full bg-rose-500 dark:bg-rose-400';
        }
      }

      // 5. 词条文本刷新
      const meaningEl = document.querySelector('.tarot-card-meaning') as HTMLElement;
      if (meaningEl) meaningEl.textContent = isUpright ? card.upright : card.reversed;

      const adviceEl = document.querySelector('.tarot-card-advice') as HTMLElement;
      if (adviceEl) adviceEl.textContent = isUpright ? card.uprightAdvice : card.reversedAdvice;
    }

    // 第一次打开运行单次覆写以防止服务端和客户端渲染冲突
    updateCard(generateTarot());

    const redrawBtn = document.getElementById('tarot-redraw');
    if (redrawBtn) {
      redrawBtn.addEventListener('click', () => {
        if (!cardEl) return;

        cardEl.classList.remove('flipped');
        flipped = false;

        setTimeout(() => {
          const data = generateTarot();
          updateCard(data);

          setTimeout(() => {
            flipped = true;
            cardEl.classList.add('flipped');
          }, 300);
        }, 400);
      });
    }

    if (particles && particles.childElementCount === 0) {
      for (let i = 0; i < 20; i++) {
        const dot = document.createElement('div');
        dot.className = 'tarot-dot';
        dot.style.left = Math.random() * 100 + '%';
        dot.style.top = Math.random() * 100 + '%';
        dot.style.animationDelay = Math.random() * 6 + 's';
        dot.style.animationDuration = (4 + Math.random() * 4) + 's';
        const size = 1 + Math.random() * 1.5;
        dot.style.width = size + 'px';
        dot.style.height = size + 'px';
        particles.appendChild(dot);
      }
    }
  }

  document.addEventListener('astro:page-load', initTarot);
</script>

<style is:global>
  .tarot-page { position: relative; }
  .tarot-page::before {
    content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background:
      radial-gradient(ellipse 70% 40% at 50% -10%, rgba(59, 130, 246, 0.04), transparent),
      radial-gradient(ellipse 50% 40% at 85% 100%, rgba(245, 158, 11, 0.02), transparent);
  }
  .dark .tarot-page::before {
    background:
      radial-gradient(ellipse 70% 40% at 50% -10%, rgba(59, 130, 246, 0.07), transparent),
      radial-gradient(ellipse 50% 40% at 85% 100%, rgba(245, 158, 11, 0.04), transparent);
