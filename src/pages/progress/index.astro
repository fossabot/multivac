---
import MainLayout from '../../layouts/MainLayout.astro';
import { Icon } from 'astro-icon/components';
---

<MainLayout title="忽已晚" description="回归日常的时间感知组件">
  <section class="chinese-progress-page min-h-[82vh] flex items-center justify-center px-4 pt-24 pb-16 select-none overflow-hidden">
    
    <div class="ink-wash-glow"></div>

    <div class="w-full max-w-lg relative z-10">

      <!-- 头部 -->
      <div class="text-center mb-14">
        <span id="progress-date" class="text-xs tracking-[0.25em] font-mono text-stone-400 dark:text-stone-500 uppercase"></span>
        <h1 class="text-xl md:text-2xl font-serif tracking-[0.15em] text-stone-800 dark:text-stone-200 font-medium mt-3 leading-relaxed">
          连雨不知春去，一晴方觉夏深。
        </h1>
        <div class="w-12 h-[1px] bg-red-700/20 dark:bg-amber-600/30 mx-auto mt-5"></div>
      </div>

      <!-- 卡片容器 -->
      <div class="chinese-card-stack flex flex-col gap-6">

        <!-- 岁律（年） -->
        <div class="chinese-item-card transition-all duration-300" data-id="year">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3.5">
              <Icon name="square-dot" class="w-4 h-4 text-red-700/60 dark:text-amber-600/50" />
              <div class="flex items-baseline gap-2.5">
                <span class="text-base font-serif tracking-widest font-medium text-stone-700 dark:text-stone-300 card-title">岁律</span>
                <span class="text-xs font-mono text-stone-400 dark:text-stone-500 uppercase card-subtitle"></span>
              </div>
            </div>
            <div class="flex items-baseline font-serif">
              <span class="progress-value text-2xl font-light tracking-tighter tabular-nums text-red-800 dark:text-amber-500/80" data-target="0">0</span>
              <span class="text-xs text-stone-400 dark:text-stone-600 ml-0.5 font-sans">%</span>
            </div>
          </div>
          <div class="chinese-bar-track h-[4px] w-full bg-stone-200/60 dark:bg-stone-800/60 rounded-full overflow-hidden">
            <div class="chinese-bar-fill h-full rounded-full w-0 transition-all duration-1000 ease-out" style="background: linear-gradient(90deg, #991b1b 0%, #b45309 100%);" data-width="0" />
          </div>
          <div class="flex items-center justify-between mt-3 text-xs font-serif text-stone-400 dark:text-stone-500">
            <span class="text-left tracking-wide card-footer-left"></span>
            <span class="right-label text-right text-stone-400 dark:text-stone-500 tracking-wide card-footer-right"></span>
          </div>
        </div>

        <!-- 时节（季度） -->
        <div class="chinese-item-card transition-all duration-300" data-id="quarter">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3.5">
              <Icon name="progress-quarter" class="w-4 h-4 text-red-700/60 dark:text-amber-600/50" />
              <div class="flex items-baseline gap-2.5">
                <span class="text-base font-serif tracking-widest font-medium text-stone-700 dark:text-stone-300 card-title">时节</span>
                <span class="text-xs font-mono text-stone-400 dark:text-stone-500 uppercase card-subtitle"></span>
              </div>
            </div>
            <div class="flex items-baseline font-serif">
              <span class="progress-value text-2xl font-light tracking-tighter tabular-nums text-red-800 dark:text-amber-500/80" data-target="0">0</span>
              <span class="text-xs text-stone-400 dark:text-stone-600 ml-0.5 font-sans">%</span>
            </div>
          </div>
          <div class="chinese-bar-track h-[4px] w-full bg-stone-200/60 dark:bg-stone-800/60 rounded-full overflow-hidden">
            <div class="chinese-bar-fill h-full rounded-full w-0 transition-all duration-1000 ease-out" style="background: linear-gradient(90deg, #991b1b 0%, #b45309 100%);" data-width="0" />
          </div>
          <div class="flex items-center justify-between mt-3 text-xs font-serif text-stone-400 dark:text-stone-500">
            <span class="text-left tracking-wide card-footer-left"></span>
            <span class="right-label text-right text-stone-400 dark:text-stone-500 tracking-wide card-footer-right"></span>
          </div>
        </div>

        <!-- 月令（月） -->
        <div class="chinese-item-card transition-all duration-300" data-id="month">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3.5">
              <Icon name="progress-month" class="w-4 h-4 text-red-700/60 dark:text-amber-600/50" />
              <div class="flex items-baseline gap-2.5">
                <span class="text-base font-serif tracking-widest font-medium text-stone-700 dark:text-stone-300 card-title">月令</span>
                <span class="text-xs font-mono text-stone-400 dark:text-stone-500 uppercase card-subtitle"></span>
              </div>
            </div>
            <div class="flex items-baseline font-serif">
              <span class="progress-value text-2xl font-light tracking-tighter tabular-nums text-red-800 dark:text-amber-500/80" data-target="0">0</span>
              <span class="text-xs text-stone-400 dark:text-stone-600 ml-0.5 font-sans">%</span>
            </div>
          </div>
          <div class="chinese-bar-track h-[4px] w-full bg-stone-200/60 dark:bg-stone-800/60 rounded-full overflow-hidden">
            <div class="chinese-bar-fill h-full rounded-full w-0 transition-all duration-1000 ease-out" style="background: linear-gradient(90deg, #991b1b 0%, #b45309 100%);" data-width="0" />
          </div>
          <div class="flex items-center justify-between mt-3 text-xs font-serif text-stone-400 dark:text-stone-500">
            <span class="text-left tracking-wide card-footer-left"></span>
            <span class="right-label text-right text-stone-400 dark:text-stone-500 tracking-wide card-footer-right"></span>
          </div>
        </div>

        <!-- 七曜（周） -->
        <div class="chinese-item-card transition-all duration-300" data-id="week">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3.5">
              <Icon name="progress-week" class="w-4 h-4 text-red-700/60 dark:text-amber-600/50" />
              <div class="flex items-baseline gap-2.5">
                <span class="text-base font-serif tracking-widest font-medium text-stone-700 dark:text-stone-300 card-title">七曜</span>
                <span class="text-xs font-mono text-stone-400 dark:text-stone-500 uppercase card-subtitle"></span>
              </div>
            </div>
            <div class="flex items-baseline font-serif">
              <span class="progress-value text-2xl font-light tracking-tighter tabular-nums text-red-800 dark:text-amber-500/80" data-target="0">0</span>
              <span class="text-xs text-stone-400 dark:text-stone-600 ml-0.5 font-sans">%</span>
            </div>
          </div>
          <div class="chinese-bar-track h-[4px] w-full bg-stone-200/60 dark:bg-stone-800/60 rounded-full overflow-hidden">
            <div class="chinese-bar-fill h-full rounded-full w-0 transition-all duration-1000 ease-out" style="background: linear-gradient(90deg, #991b1b 0%, #b45309 100%);" data-width="0" />
          </div>
          <div class="flex items-center justify-between mt-3 text-xs font-serif text-stone-400 dark:text-stone-500">
            <span class="text-left tracking-wide card-footer-left"></span>
            <span class="right-label text-right text-stone-400 dark:text-stone-500 tracking-wide card-footer-right"></span>
          </div>
        </div>

        <!-- 朝暮（日） -->
        <div class="chinese-item-card transition-all duration-300" data-id="day">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3.5">
              <Icon name="progress-day" class="w-4 h-4 text-red-700/60 dark:text-amber-600/50" />
              <div class="flex items-baseline gap-2.5">
                <span class="text-base font-serif tracking-widest font-medium text-stone-700 dark:text-stone-300 card-title">朝暮</span>
                <span class="text-xs font-mono text-stone-400 dark:text-stone-500 uppercase card-subtitle"></span>
              </div>
            </div>
            <div class="flex items-baseline font-serif">
              <span class="progress-value text-2xl font-light tracking-tighter tabular-nums text-red-800 dark:text-amber-500/80" data-target="0">0</span>
              <span class="text-xs text-stone-400 dark:text-stone-600 ml-0.5 font-sans">%</span>
            </div>
          </div>
          <div class="chinese-bar-track h-[4px] w-full bg-stone-200/60 dark:bg-stone-800/60 rounded-full overflow-hidden">
            <div class="chinese-bar-fill h-full rounded-full w-0 transition-all duration-1000 ease-out" style="background: linear-gradient(90deg, #991b1b 0%, #b45309 100%);" data-width="0" />
          </div>
          <div class="flex items-center justify-between mt-3 text-xs font-serif text-stone-400 dark:text-stone-500">
            <span class="text-left tracking-wide card-footer-left"></span>
            <span class="right-label text-right text-stone-400 dark:text-stone-500 tracking-wide card-footer-right"></span>
          </div>
        </div>

      </div>

    </div>
  </section>
</MainLayout>

<script>
  import { calcAllProgress } from '../../utils/progressCalc';

  function initChineseProgress() {
    const items = calcAllProgress();
    const stack = document.querySelector('.chinese-card-stack');
    if (!stack) return;

    // 更新头部日期
    const now = new Date();
    const dateEl = document.getElementById('progress-date');
    if (dateEl) {
      dateEl.textContent = `${now.getFullYear()} . ${String(now.getMonth() + 1).padStart(2, '0')} . ${String(now.getDate()).padStart(2, '0')}`;
    }

    // 填充每张卡片的动态数据
    items.forEach(item => {
      const card = stack.querySelector(`[data-id="${item.id}"]`);
      if (!card) return;

      const subtitle = card.querySelector('.card-subtitle');
      const valEl = card.querySelector('.progress-value') as HTMLElement | null;
      const barEl = card.querySelector('.chinese-bar-fill') as HTMLElement | null;
      const footerLeft = card.querySelector('.card-footer-left');
      const footerRight = card.querySelector('.card-footer-right');

      if (subtitle) subtitle.textContent = item.subtitle;
      if (valEl) valEl.dataset.target = item.progress.toString();
      if (barEl) barEl.dataset.width = item.progress.toString();
      if (footerLeft) footerLeft.textContent = item.footerLeft;
      if (footerRight) footerRight.textContent = item.footerRight;
    });

    // 动画
    const cards = stack.querySelectorAll('.chinese-item-card');

    function startAnimation() {
      cards.forEach(card => {
        const valEl = card.querySelector('.progress-value') as HTMLElement | null;
        const barEl = card.querySelector('.chinese-bar-fill') as HTMLElement | null;
        if (!valEl || !barEl) return;

        const target = parseInt(valEl.dataset.target || '0');
        const width = barEl.dataset.width || '0';

        requestAnimationFrame(() => {
          barEl.style.width = `${width}%`;
        });

        let current = 0;
        const duration = 1000;
        const startTime = performance.now();
        const valueEl = valEl;

        function tick(now: number) {
          const elapsed = now - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          current = Math.floor(eased * target);
          valueEl.textContent = current.toString();
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      });
    }

    function syncDayRealtime() {
      const dayCard = stack!.querySelector('[data-id="day"]');
      if (!dayCard) return;

      const valEl = dayCard.querySelector('.progress-value') as HTMLElement | null;
      const barEl = dayCard.querySelector('.chinese-bar-fill') as HTMLElement | null;
      const rightLabel = dayCard.querySelector('.right-label');
      if (!valEl || !barEl) return;

      const now = new Date();
      const startOfDay = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      const dayProgress = ((now.getTime() - startOfDay.getTime()) / (24 * 60 * 60 * 1000)) * 100;
      const hoursLeft = 24 - now.getHours();

      valEl.textContent = Math.floor(dayProgress).toString();
      barEl.dataset.width = dayProgress.toString();
      barEl.style.width = `${dayProgress}%`;
      if (rightLabel) rightLabel.textContent = `余 ${hoursLeft} 小时`;
    }

    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        startAnimation();
        syncDayRealtime();
        observer.disconnect();
      }
    }, { threshold: 0.05 });

    observer.observe(stack);

    const timer = setInterval(syncDayRealtime, 60000);
    document.addEventListener('astro:after-swap', () => clearInterval(timer));
  }

  document.addEventListener('astro:page-load', initChineseProgress);
</script>

<style is:global>
  .chinese-progress-page { position: relative; }
  
  .ink-wash-glow {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background: radial-gradient(circle at 50% 15%, rgba(153, 27, 27, 0.01), transparent 40%);
  }

  .chinese-item-card {
    border: 1px solid rgba(139, 92, 26, 0.05);
    border-radius: 14px;
    padding: 22px 26px;
    background: rgba(253, 252, 249, 0.45);
    backdrop-filter: blur(12px);
  }
  
  .dark .chinese-item-card {
    border-color: rgba(245, 158, 11, 0.05);
    background: rgba(28, 25, 23, 0.4);
  }

  .chinese-item-card:hover {
    transform: translateY(-1px);
    border-color: rgba(153, 27, 27, 0.15);
    background: rgba(253, 252, 249, 0.7);
  }
  
  .dark .chinese-item-card:hover {
    border-color: rgba(245, 158, 11, 0.15);
    background: rgba(34, 30, 28, 0.5);
  }
</style>
