---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import PasswordProtect from '../../components/PasswordProtect.astro';

export async function getStaticPaths() {
	const posts = await getCollection('post', ({ data, body, id }) => !data.draft && typeof body === 'string' && !id.startsWith('about/'));

	return posts.map((post) => {
		return {
			params: { slug: post.id.toLowerCase() },
			props: post,
		};
	});
}
type Props = CollectionEntry<'post'>;

const post = Astro.props;
const { Content } = await render(post);

const isEncrypted = !!post.data.password;
let encryptedContent = '';
let rawContentForStats = '';

if (isEncrypted && post.data.password) {
	const { encryptContent } = await import('../../scripts/crypto');
	const html = post.rendered?.html ?? '';
	const contentToEncrypt = html || (typeof post.body === 'string' ? post.body : '');
	if (!contentToEncrypt) {
		throw new Error(`[加密] 文章 "${post.id}" 没有可加密的内容，请检查 rendered.html 和 body`);
	}
	encryptedContent = await encryptContent(contentToEncrypt, post.data.password);
	rawContentForStats = contentToEncrypt;
}
---

<BlogPost {...post.data} id={post.id} encryptedPayload={isEncrypted ? encryptedContent : undefined} rawContentForStats={isEncrypted ? rawContentForStats : undefined}>
	{isEncrypted ? (
		<PasswordProtect passwordHint={post.data.passwordHint} />
	) : (
		<Content />
	)}
</BlogPost>
